---
---

<section class="hero">
  <h1 class="hero-mark">LATENT</h1>
  <div class="hero-designation">the Ritual</div>
  <p class="hero-tagline">A photographic developer for the digital age.</p>

  <div class="hero-screen">
    <video
      class="hero-video"
      muted
      playsinline
      preload="auto"
      poster="/hero-poster.jpg"
      aria-label="Latent the Ritual — a photograph developing in the Darkroom"
    >
      <source src="/hero.webm" type="video/webm" />
      <source src="/hero.mp4" type="video/mp4" />
    </video>
    <button class="hero-replay" type="button" aria-label="Replay the develop">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M3 12a9 9 0 1 0 3-6.7L3 8" />
        <path d="M3 3v5h5" />
      </svg>
      <span>Replay</span>
    </button>
  </div>

  <div class="scroll-cue">Scroll</div>
</section>
