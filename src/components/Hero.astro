---
import { Picture } from 'astro:assets';
import darkroom from '../assets/darkroom.png';
---

<section class="hero">
  <h1 class="hero-mark">LATENT</h1>
  <div class="hero-designation">the Ritual</div>
  <p class="hero-tagline">A photographic developer for the digital age.</p>

  <div class="hero-screen">
    <Picture
      src={darkroom}
      formats={['avif', 'webp']}
      widths={[640, 1024, 1600, 2560]}
      sizes="(min-width: 1320px) 1280px, 100vw"
      alt="Latent the Ritual — the Darkroom"
      loading="eager"
      fetchpriority="high"
    />
  </div>

  <div class="scroll-cue">Scroll</div>
</section>
