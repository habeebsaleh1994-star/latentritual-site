<section class="story" id="story">
  <div class="section-label reveal">Light Table · Story Mode</div>
  <h2 class="section-heading center reveal reveal-heading" style="--reveal-delay: 80ms">The arrangement is the story.</h2>
  <p class="section-body reveal" style="margin: 0 auto; --reveal-delay: 160ms">
    One photograph is a frame. A sequence — paired as spreads, paced with
    breath pages, opened with a cover — becomes a photo essay. Built in the
    Light Table. Read like a book.
  </p>

  <div class="story-video reveal" style="--reveal-delay: 240ms">
    <video
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      poster="/story-mode-canvas-poster.jpg"
      aria-label="Latent the Ritual — arranging photographs into a sequence in the Light Table"
    >
      <source src="/story-mode-canvas.webm" type="video/webm" />
      <source src="/story-mode-canvas.mp4" type="video/mp4" />
    </video>
  </div>

  <p class="story-connector reveal" style="--reveal-delay: 320ms">Watch your story come to life.</p>

  <div class="story-video reveal" style="--reveal-delay: 400ms">
    <video
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      poster="/story-mode-reader-poster.jpg"
      aria-label="Latent the Ritual — the photo essay unfolding in the Story Mode reader"
    >
      <source src="/story-mode-reader.webm" type="video/webm" />
      <source src="/story-mode-reader.mp4" type="video/mp4" />
    </video>
  </div>
</section>
