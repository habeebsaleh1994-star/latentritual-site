---
// Footer — the house's letters desk.
//
// Signups POST to our same-origin /api/subscribe proxy (a Cloudflare Pages
// Function) which relays to Buttondown's API — bypassing the Turnstile gate on
// the public embed form.
const SUBSCRIBE_ENDPOINT = '/api/subscribe';
---

<footer id="letters">
  <div class="footer-mark reveal">LATENT</div>
  <p class="footer-line reveal" style="--reveal-delay: 80ms">A photographic developer for the digital age.</p>

  <div class="footer-links reveal" style="--reveal-delay: 160ms">
    <a href="/ritual">The Ritual</a>
    <a href="/moment">The Moment</a>
    <a href="/lab">The Lab</a>
    <a href="mailto:contact@latentritual.com">Contact</a>
    <a href="https://instagram.com/latentritual" target="_blank" rel="noopener noreferrer">Instagram</a>
    <a href="/privacy">Privacy</a>
    <a href="/terms">Terms</a>
  </div>

  <div class="footer-subscribe reveal" id="notify" style="--reveal-delay: 240ms" data-newsletter>
    <p class="footer-subscribe-line">
      Occasional letters from the person making Latent: the work, the
      thinking, and the word when it ships.
    </p>
    <form
      class="footer-subscribe-form"
      action={SUBSCRIBE_ENDPOINT}
      method="post"
      data-newsletter-form
    >
      <label class="visually-hidden" for="newsletter-email">Email address</label>
      <input
        id="newsletter-email"
        class="footer-subscribe-input"
        type="email"
        name="email"
        required
        autocomplete="email"
        placeholder="your email"
      />
      <input type="text" name="website" tabindex="-1" autocomplete="off" aria-hidden="true"
             style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0;pointer-events:none" />
      <button type="submit" class="footer-subscribe-submit">Subscribe</button>
    </form>
    <p class="footer-subscribe-error" data-newsletter-error hidden role="alert">
      That email doesn't look right.
    </p>
    <p class="footer-subscribe-done" data-newsletter-done hidden role="status" aria-live="polite">
      You&rsquo;re subscribed. Letters will be rare.
    </p>
  </div>

  <p class="footer-meta reveal" style="--reveal-delay: 320ms">Habib Saleh, founder and artist, Joun, Lebanon. &copy; 2026.</p>

  <button class="footer-lamp" type="button" data-lamp aria-pressed="false" title="Warm the room after dark">Lamplight</button>
</footer>
