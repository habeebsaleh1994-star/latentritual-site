---
import { Picture } from 'astro:assets';
import studio from '../assets/studio.png';
import workbench from '../assets/workbench.png';
import lighttable from '../assets/lighttable.png';
import darkroom from '../assets/darkroom.png';

const screens = [
  { id: 'studio',     name: 'Studio',      src: studio,     desc: 'Where your work lives, over time.' },
  { id: 'workbench',  name: 'Workbench',   src: workbench,  desc: 'Resume where you left off.' },
  { id: 'lighttable', name: 'Light Table', src: lighttable, desc: 'Sort, rate, sequence, decide.' },
  { id: 'darkroom',   name: 'Darkroom',    src: darkroom,   desc: 'Develop. Retouch. Proof. Print.' },
];
---

<section class="complete">
  <div class="complete-tabs section-label reveal">
    {screens.map((s, i) => (
      <>
        {i > 0 && <span class="complete-tab-divider">·</span>}
        <button
          type="button"
          class:list={['complete-tab', { 'is-active': i === 0 }]}
          data-target={s.id}
        >
          {s.name}
        </button>
      </>
    ))}
  </div>

  <h2 class="section-heading center reveal reveal-heading" style="--reveal-delay: 80ms">One place, from import to print.</h2>
  <p class="section-body reveal" style="margin: 0 auto; --reveal-delay: 160ms">
    Latent carries a photograph the whole way, from RAW to a finished print,
    without ever leaving the app. Library, contact sheet, developer, retoucher,
    soft-proof, export, it's all in here.
  </p>

  <div class="complete-screens reveal" style="--reveal-delay: 240ms">
    {screens.map((s, i) => (
      <div class:list={['complete-screen', { 'is-active': i === 0 }]} data-screen={s.id}>
        <Picture
          src={s.src}
          formats={['avif', 'webp']}
          widths={[640, 1024, 1600, 2560]}
          sizes="(min-width: 1432px) 1352px, 100vw"
          alt={`Latent the Ritual, ${s.name}`}
          loading="lazy"
        />
      </div>
    ))}
  </div>

  <div class="complete-list">
    {screens.map((s, i) => (
      <div
        class:list={['complete-item reveal', { 'is-active': i === 0 }]}
        data-item={s.id}
        style={`--reveal-delay: ${i * 80}ms`}
      >
        <div class="complete-item-label">{s.name}</div>
        <div class="complete-item-name">{s.desc}</div>
      </div>
    ))}
  </div>
</section>
