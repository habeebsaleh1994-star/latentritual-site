<section class="bridge">
  <div class="section-label reveal">The Catalog Bridge</div>
  <h2 class="section-heading center reveal reveal-heading" style="--reveal-delay: 80ms">Bring your whole library with you.</h2>
  <p class="section-body reveal" style="margin: 0 auto; --reveal-delay: 160ms">
    Switching from Lightroom or Capture One? Your ratings, labels, keywords and
    captions come over. Your photographs start fresh, as negatives.
  </p>

  <div class="bridge-shots reveal" style="--reveal-delay: 240ms">
    <figure class="bridge-shot">
      <img src="/bridge-choose.webp" width="1264" height="1408" alt="The Catalog Bridge, choosing a Lightroom or Capture One catalog to read" loading="lazy" />
      <figcaption>Point it at your catalog.</figcaption>
    </figure>
    <figure class="bridge-shot">
      <img src="/bridge-receipt.webp" width="1264" height="1408" alt="The Catalog Bridge receipt, showing every photograph accounted for and the source catalog left unmodified" loading="lazy" />
      <figcaption>Get back an honest receipt.</figcaption>
    </figure>
  </div>
</section>
