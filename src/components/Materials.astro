---
// Materials — the film and the paper, presented as materials rather than a
// spec sheet. Keeps the calm grid and the heading-tint interaction (hovering a
// stock tints the heading toward that film's colour, via --hover-tint written
// by quiet.js). Two refinements from the previous version:
//   1. No fixed counts. The headline and the "and more" tiles imply breadth
//      without a number that goes stale as the catalog grows.
//   2. A whisper of film: each swatch carries a soft emulsion sheen instead of
//      a flat fill, and on hover it glows in its own colour.
const stocks = [
  { name: 'Portra 400', family: 'Kodak', swatch: '#E8C4A0' },
  { name: 'Portra 160', family: 'Kodak', swatch: '#D4B896' },
  { name: 'Portra 800', family: 'Kodak', swatch: '#D4A878' },
  { name: 'Gold 200', family: 'Kodak', swatch: '#DAB36E' },
  { name: 'Ultramax 400', family: 'Kodak', swatch: '#C4A854' },
  { name: 'Ektar 100', family: 'Kodak', swatch: '#D4665A' },
  { name: 'HP5 Plus', family: 'Ilford', swatch: '#9A9A9A' },
  { name: 'Tri-X 400', family: 'Kodak', swatch: '#B0B0B0' },
  { name: 'Delta 3200', family: 'Ilford', swatch: '#787878' },
  { name: 'Pan F Plus 50', family: 'Ilford', swatch: '#B8B8B8' },
  { name: 'Provia 100F', family: 'Fuji', swatch: '#7BA3C9' },
  { name: 'Velvia 50', family: 'Fuji', swatch: '#5A9E6A' },
  { name: 'Superia 400', family: 'Fuji', swatch: '#7EB89A' },
  { name: 'CineStill 800T', family: 'CineStill', swatch: '#C9956A' },
];

// Real print papers, grouped by darkroom process: RA-4 colour, B&W silver,
// Cibachrome dye-bleach, ECP cinema print. Swatch = the paper's BASE TONE
// (its white), not a colour cast.
const papers = [
  { name: 'Portra Endura', family: 'RA-4', swatch: '#E7DAC6' },
  { name: 'Supra Endura', family: 'RA-4', swatch: '#E6D6BE' },
  { name: 'Ultra Endura', family: 'RA-4', swatch: '#EAD8BC' },
  { name: 'Endura Metallic', family: 'RA-4', swatch: '#B6B4AE' },
  { name: 'Crystal Archive Supreme', family: 'RA-4', swatch: '#D8DEDC' },
  { name: 'Multigrade FB Classic', family: 'Silver', swatch: '#C9C7C1' },
  { name: 'Multigrade Warmtone', family: 'Silver', swatch: '#D3CBBC' },
  { name: 'Multigrade Cooltone', family: 'Silver', swatch: '#C3C8CB' },
  { name: 'Multigrade Art 300', family: 'Silver', swatch: '#D8D2C6' },
  { name: 'Fomatone Classic', family: 'Silver', swatch: '#D2C9B8' },
  { name: 'Forte Polywarmtone', family: 'Silver', swatch: '#D6CDB8' },
  { name: 'Ilfochrome Classic', family: 'Cibachrome', swatch: '#ECE6DA' },
  { name: 'Kodak 2383', family: 'ECP', swatch: '#D9C7A8' },
  { name: 'Kodak 2393 Premier', family: 'ECP', swatch: '#D6C2A0' },
];
---

<section class="materials">
  <div class="materials-header">
    <div class="section-label reveal">Materials</div>
    <h2 class="section-heading center reveal reveal-heading" style="--reveal-delay: 80ms">Every emulsion, its own character.</h2>
    <p class="section-body reveal" style="margin: 0 auto; --reveal-delay: 160ms">
      Real film and darkroom paper, modeled by how they actually behave &mdash;
      not presets, not filters. The film carries its own grain, colour and
      halation, then the negative prints onto real paper matched to its
      chemistry. The same choices you&rsquo;d make in a lab.
    </p>
  </div>

  <div class="materials-subhead reveal" style="--reveal-delay: 200ms">The film</div>
  <div class="stocks-grid">
    {stocks.map((stock, i) => (
      <div class="stock reveal" data-swatch={stock.swatch} style={`--reveal-delay: ${240 + i * 30}ms`}>
        <div class="stock-swatch" style={`--sw: ${stock.swatch}`}></div>
        <div class="stock-info">
          <div class="stock-name">{stock.name}</div>
          <div class="stock-family">{stock.family}</div>
        </div>
      </div>
    ))}
    <div class="stock-more reveal" style={`--reveal-delay: ${240 + stocks.length * 30}ms`}>
      <span>and more</span>
    </div>
  </div>

  <div class="materials-subhead reveal">The paper</div>
  <div class="stocks-grid">
    {papers.map((paper, i) => (
      <div class="stock reveal" data-swatch={paper.swatch} style={`--reveal-delay: ${i * 30}ms`}>
        <div class="stock-swatch" style={`--sw: ${paper.swatch}`}></div>
        <div class="stock-info">
          <div class="stock-name">{paper.name}</div>
          <div class="stock-family">{paper.family}</div>
        </div>
      </div>
    ))}
    <div class="stock-more reveal" style={`--reveal-delay: ${papers.length * 30}ms`}>
      <span>and more</span>
    </div>
  </div>

  <p class="scanner-line reveal">
    And five scans for the way film comes back from the lab (<span class="accent">Noritsu, Frontier, Pakon, flatbed, DSLR</span>).
  </p>
</section>

<style>
  /* A whisper of emulsion: the swatch gains depth (a soft sheen top-left, a
     little density bottom-right) instead of a flat dot. --sw is the stock's
     colour, set inline per swatch. */
  .stock-swatch {
    background:
      radial-gradient(circle at 34% 28%, rgba(255, 255, 255, 0.34), rgba(255, 255, 255, 0) 52%),
      radial-gradient(circle at 68% 78%, rgba(0, 0, 0, 0.22), rgba(0, 0, 0, 0) 60%),
      var(--sw, #888);
    box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.18);
  }
  /* On hover the swatch lifts and glows in its own colour (global.css already
     scales it to 1.12; this deepens the gesture). */
  .stock:hover .stock-swatch {
    transform: scale(1.16);
    box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.18), 0 0 18px var(--sw);
  }

  /* The "and more" tile — breadth without a number that dates. */
  .stock-more {
    grid-column: span 2;
    background: var(--bg);
    padding: 20px 18px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .stock-more span {
    font-family: 'Lora', Georgia, serif;
    font-style: italic;
    font-size: 14px;
    color: var(--text-ghost);
  }

  @media (max-width: 520px) {
    .stock-more { grid-column: span 2; }
  }
</style>
