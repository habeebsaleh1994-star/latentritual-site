<section class="price" id="price">
  <h2 class="price-heading reveal reveal-heading">Buy once. Develop forever.</h2>
  <p class="price-sub reveal" style="--reveal-delay: 80ms">Or subscribe, if you'd rather.</p>

  <div class="price-grid">

    <div class="price-card reveal" style="--reveal-delay: 160ms">
      <div class="price-tier">Monthly</div>
      <div class="price-amount">$14.99</div>
      <div class="price-unit">per month</div>
      <p class="price-note">All of Latent, Ritual on Mac and iPad, Moment on iPhone.</p>
      <a href="/#notify" class="price-button">Notify me at launch</a>
    </div>

    <div class="price-card featured reveal" style="--reveal-delay: 240ms">
      <div class="price-tier">Annual · Founding</div>
      <div class="price-amount">$99</div>
      <div class="price-unit">per year, locked forever</div>
      <p class="price-note">First 90 days only. Your price never changes, even when others go up.</p>
      <a href="/#notify" class="price-button">Notify me at launch</a>
    </div>

    <div class="price-card reveal" style="--reveal-delay: 320ms">
      <div class="price-tier">Lifetime</div>
      <div class="price-amount">$399</div>
      <div class="price-unit">one time</div>
      <p class="price-note">Buy once. Major updates included. Never another invoice.</p>
      <a href="/#notify" class="price-button">Notify me at launch</a>
    </div>

  </div>

  <p class="trial-line reveal" style="--reveal-delay: 400ms">Just want the iPhone app? Moment is $4.99/month, or $99 lifetime.</p>
  <p class="trial-line reveal" style="--reveal-delay: 480ms">At launch: a 14-day free trial, no credit card required.</p>
</section>
