<section class="price" id="price">
  <h2 class="price-heading reveal reveal-heading">The darkroom, wherever you work.</h2>
  <p class="price-sub reveal" style="--reveal-delay: 80ms">Ritual on Mac and iPad. Moment on iPhone.</p>

  <div class="price-grid">

    <div class="price-card reveal" style="--reveal-delay: 160ms">
      <div class="price-tier">Latent Suite · Monthly</div>
      <div class="price-amount">$14.99</div>
      <div class="price-unit">per month</div>
      <p class="price-note">Ritual on Mac and iPad, plus Moment on iPhone.</p>
      <a href="/#notify" class="price-button">Notify me at launch</a>
    </div>

    <div class="price-card featured reveal" style="--reveal-delay: 240ms">
      <div class="price-tier">Latent Suite · Founding Annual</div>
      <div class="price-amount">$99</div>
      <div class="price-unit">per year for early subscribers</div>
      <p class="price-note">First 90 days only. Regular annual pricing will be $149/year.</p>
      <a href="/#notify" class="price-button">Notify me at launch</a>
    </div>

    <div class="price-card reveal" style="--reveal-delay: 320ms">
      <div class="price-tier">Moment · iPhone</div>
      <div class="price-amount">$4.99</div>
      <div class="price-unit">per month, or $39.99/year</div>
      <p class="price-note">A focused iPhone darkroom for developing photographs in the moment.</p>
      <a href="/#notify" class="price-button">Notify me at launch</a>
    </div>

  </div>

  <p class="trial-line reveal" style="--reveal-delay: 400ms">Latent Suite annual renews at $149/year after the founding launch period.</p>
  <p class="trial-line reveal" style="--reveal-delay: 480ms">At launch: a 14-day free trial, no credit card required.</p>
</section>
