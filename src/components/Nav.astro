---
// Nav — global navigation.
//
// Over the homepage's full-bleed Develop hero, the nav sits transparent (no
// dark band) and its small wordmark steps aside, because the giant hero
// wordmark is right there. The moment you scroll past the hero, the nav fogs
// in to its normal frosted bar and the wordmark fades up. On every other page
// (no full-bleed hero) the nav behaves exactly as before — frosted from the top.
const isHome = Astro.url.pathname === '/';
---

<nav class={isHome ? 'over-hero' : ''} data-nav>
  <a class="wordmark" href="/">LATENT</a>
  <ul>
    <li><a href="/#ritual">The Ritual</a></li>
    <li><a href="/moment">The Moment</a></li>
    <li><a href="/resolve">The Lab</a></li>
    <li><a href="/about">About</a></li>
    <li><a href="/#price" class="cta">Buy</a></li>
  </ul>
</nav>

<style>
  /* Homepage, at the very top: dissolve the frosted bar so the photograph
     reads full-bleed, and let the hero's wordmark carry the brand alone. */
  nav.over-hero:not(.is-scrolled) {
    background: transparent;
    -webkit-backdrop-filter: none;
    backdrop-filter: none;
    border-bottom-color: transparent;
  }
  nav.over-hero:not(.is-scrolled) .wordmark {
    opacity: 0;
    pointer-events: none;
  }
  nav.over-hero .wordmark {
    transition: opacity 0.5s ease;
  }
</style>

<script>
  // Fog the nav in once the hero is behind you.
  const nav = document.querySelector('nav.over-hero');
  if (nav) {
    const sync = () => nav.classList.toggle('is-scrolled', window.scrollY > 80);
    sync();
    window.addEventListener('scroll', sync, { passive: true });
  }
</script>
