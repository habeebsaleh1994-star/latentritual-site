---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogImageAlt?: string;
}

const {
  title = 'Latent — a photographic developer for the digital age',
  description = 'A house of three instruments, one negative-to-print engine: The Ritual on Mac and iPad, The Moment on iPhone, The Lab in DaVinci Resolve.',
  ogImage = '/og.png?v=4',
  ogImageAlt = 'Latent — one house, three instruments',
} = Astro.props;

const ogImageURL = `https://latentritual.com${ogImage}`;
const canonicalURL = new URL(Astro.url.pathname, 'https://latentritual.com').href;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Latent',
  applicationCategory: 'MultimediaApplication',
  operatingSystem: 'macOS, iPadOS, iOS',
  description,
  url: 'https://latentritual.com',
};
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#1A1614" />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <title>{title}</title>

    <link rel="icon" type="image/svg+xml" href="/icon.svg?v=4" />
    <link rel="icon" type="image/png" sizes="32x32" href="/icon-32.png?v=4" />
    <link rel="apple-touch-icon" sizes="180x180" href="/icon-180.png?v=4" />

    <!-- Fonts are self-hosted (styles/fonts.css) — no third-party requests. -->
    <link rel="preload" as="font" type="font/woff2" crossorigin href="/fonts/outfit-latin.woff2" />
    <slot name="head" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- The lamplit evening, decided before first paint: the visitor's stored
         choice wins; otherwise the room warms after local sunset. quiet.js
         wires the footer lamp that overrides this. -->
    <script is:inline>
      (() => {
        try {
          var stored = localStorage.getItem('latent-lamp');
          var hour = new Date().getHours();
          var evening = stored ? stored === 'on' : (hour >= 19 || hour < 6);
          if (evening) document.documentElement.classList.add('is-evening');
        } catch (e) {}
      })();
    </script>
  </head>

  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <slot />
    <script>
      import '../scripts/quiet.js';
      import '../scripts/newsletter.js';
    </script>
  </body>
</html>
