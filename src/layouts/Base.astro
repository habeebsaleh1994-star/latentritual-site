---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogImageAlt?: string;
}

const {
  title = 'Latent the Ritual — A photographic developer for the digital age',
  description = 'A complete digital darkroom for serious photographers. Film, light, paper. Develop, retouch, proof, print — in one place.',
  ogImage = '/og.png?v=3',
  ogImageAlt = 'Latent the Ritual — a photographic developer for the digital age',
} = Astro.props;

const ogImageURL = `https://latentritual.com${ogImage}`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Latent the Ritual',
  applicationCategory: 'MultimediaApplication',
  operatingSystem: 'macOS, iPadOS, iOS',
  description,
  url: 'https://latentritual.com',
};
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#1A1614" />
    <link rel="canonical" href="https://latentritual.com" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://latentritual.com" />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <title>{title}</title>

    <link rel="icon" type="image/svg+xml" href="/icon.svg?v=4" />
    <link rel="icon" type="image/png" sizes="32x32" href="/icon-32.png?v=4" />
    <link rel="apple-touch-icon" sizes="180x180" href="/icon-180.png?v=4" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@200;300;400;500&family=JetBrains+Mono:wght@300;400&family=Lora:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>

  <body>
    <slot />
    <script>
      import '../scripts/quiet.js';
      import '../scripts/newsletter.js';
    </script>
  </body>
</html>
