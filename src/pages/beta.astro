---
import Base from '../layouts/Base.astro';

// One door for all three instruments. The page is static; a small script
// reads ?app=ritual|moment|lab and re-dresses the card — lockup, kicker,
// copy, hidden tag, foot link. Without JS (or without the parameter) it
// stands as The Moment's door, which is where the existing links point.
//
// Signups POST to our same-origin /api/subscribe proxy (a Cloudflare Pages
// Function) which relays to Buttondown's API. The hidden `tag` marks which
// instrument the request belongs to.
const SUBSCRIBE_ENDPOINT = '/api/subscribe';
---

<Base
  title="Join the beta — Latent"
  description="Latent's instruments are let out quietly. Leave your address and the invitation follows by letter."
  ogImageAlt="Latent — join the beta"
>
  <main class="beta" id="main">
    <div class="beta-glow" aria-hidden="true"></div>

    <div class="beta-lockup">
      <img class="beta-icon" src="/moment-icon.png" width="64" height="64" alt="" data-beta-icon />
      <div class="beta-wordmark" data-beta-wordmark>The&nbsp;Moment</div>
    </div>

    <section class="beta-card" data-newsletter>
      <div class="beta-kicker" data-beta-kicker>Now in beta</div>
      <h1 class="beta-title" data-beta-title>Ready for its first eyes.</h1>
      <p class="beta-lead" data-beta-lead>
        The Moment has been developing quietly. A few photographers are being
        let in early, to hold it, to use it, to tell us what they keep.
      </p>

      <form
        class="beta-form"
        action={SUBSCRIBE_ENDPOINT}
        method="post"
        data-newsletter-form
      >
        <label class="visually-hidden" for="beta-email">Email address</label>
        <input
          id="beta-email"
          class="beta-input"
          type="email"
          name="email"
          required
          autocomplete="email"
          inputmode="email"
          placeholder="your email"
        />
        <input type="hidden" name="tag" value="moment-beta" data-beta-tag />
        <input type="text" name="website" tabindex="-1" autocomplete="off" aria-hidden="true"
               style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0;pointer-events:none" />
        <button type="submit" class="beta-submit" data-beta-submit>Request an invitation</button>
      </form>

      <p class="beta-fine" data-beta-fine>The invitation arrives by letter, alongside the occasional word from Latent.</p>

      <p class="beta-error" data-newsletter-error hidden role="alert">That email doesn't look right.</p>
      <p class="beta-done" data-newsletter-done hidden role="status" aria-live="polite" data-beta-done>
        It's on its way. Your invitation will arrive by letter.
      </p>
    </section>

    <p class="beta-foot"><span data-beta-foot>Soon, on iPhone.</span> &nbsp;·&nbsp; <a href="/moment" data-beta-foot-link>See what it does</a></p>
  </main>

  <script>
    // Re-dress the door for the instrument named in the URL.
    const doors = {
      ritual: {
        icon: false,
        wordmark: 'The Ritual',
        kicker: 'Now in private beta',
        title: 'The workroom opens quietly.',
        lead:
          'The Ritual has been taking shape on Mac and iPad. A few photographers are being let in early — to bring a body of work and stay a while.',
        submit: 'Request an invitation',
        tag: 'ritual-beta',
        fine: 'The invitation arrives by letter, alongside the occasional word from Latent.',
        done: "It's on its way. Your invitation will arrive by letter.",
        foot: 'Soon, on Mac and iPad.',
        footLink: { href: '/ritual', label: 'See the workroom' },
      },
      moment: null, // the page as served
      lab: {
        icon: false,
        wordmark: 'The Lab',
        kicker: 'In development',
        title: 'The word, when it is real.',
        lead:
          'The Lab is in active development — the engine inside DaVinci Resolve, and the whole lab on iPhone. The waitlist gets the word when each one is ready, and nothing is sold before it is real.',
        submit: 'Join the waitlist',
        tag: 'lab-waitlist',
        fine: 'The word arrives by letter, alongside the occasional note from Latent.',
        done: "You're on the list. The word will arrive by letter.",
        foot: 'Soon, in DaVinci Resolve and on iPhone.',
        footLink: { href: '/lab', label: 'See the Lab' },
      },
    };

    const app = new URLSearchParams(window.location.search).get('app');
    const door = app && doors[app];
    if (door) {
      const set = (sel, value) => {
        const el = document.querySelector(sel);
        if (el && value != null) el.textContent = value;
      };
      const icon = document.querySelector('[data-beta-icon]');
      if (icon && !door.icon) icon.remove();
      set('[data-beta-wordmark]', door.wordmark);
      set('[data-beta-kicker]', door.kicker);
      set('[data-beta-title]', door.title);
      set('[data-beta-lead]', door.lead);
      set('[data-beta-submit]', door.submit);
      set('[data-beta-fine]', door.fine);
      set('[data-beta-done]', door.done);
      const tag = document.querySelector('[data-beta-tag]');
      if (tag instanceof HTMLInputElement) tag.value = door.tag;
      set('[data-beta-foot]', door.foot);
      const footLink = document.querySelector('[data-beta-foot-link]');
      if (footLink instanceof HTMLAnchorElement) {
        footLink.href = door.footLink.href;
        footLink.textContent = door.footLink.label;
      }
    }
  </script>

  <style>
    .beta {
      position: relative;
      min-height: 100svh;
      background: var(--bg-deep);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 72px 24px 56px;
      overflow: hidden;
    }
    .beta-glow {
      position: absolute;
      top: 42%; left: 50%;
      transform: translate(-50%, -50%);
      width: 900px; height: 900px;
      max-width: 140vw; max-height: 140vw;
      background: radial-gradient(circle, rgba(232, 196, 160, 0.08) 0%, transparent 62%);
      pointer-events: none;
    }

    .beta-lockup {
      position: relative;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 16px;
      margin-bottom: 52px;
    }
    /* The app mark, presented as the same cream tile as the launch story so
       the tap-through feels continuous. Instruments without a public icon
       stand on the wordmark alone. */
    .beta-icon {
      display: block;
      width: 64px;
      height: 64px;
      border-radius: 15px;
      box-shadow: 0 12px 34px rgba(0, 0, 0, 0.5);
    }
    .beta-wordmark {
      font-family: var(--font-display);
      font-weight: 200;
      font-size: 20px;
      letter-spacing: 0.34em;
      text-indent: 0.34em;
      text-transform: uppercase;
      color: var(--text-bright);
    }

    /* Override the global `section` padding — this card is a <section>, and
       that inherited padding otherwise opens a huge gap above the kicker and
       pushes the CTA off the first screen. */
    .beta-card { position: relative; width: 100%; max-width: 540px; padding: 0; }

    .beta-kicker {
      font-family: var(--font-label);
      font-size: 12px;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--amber-dim);
      margin-bottom: 26px;
    }
    .beta-title {
      font-family: 'Lora', Georgia, serif;
      font-weight: 500;
      font-size: clamp(34px, 8vw, 52px);
      line-height: 1.12;
      color: var(--text-bright);
      margin: 0;
    }
    .beta-lead {
      font-family: var(--font-body);
      font-weight: 300;
      font-size: 17px;
      line-height: 1.7;
      color: var(--text-muted);
      max-width: 460px;
      margin: 24px auto 0;
    }

    .beta-form {
      display: flex;
      flex-direction: column;
      gap: 12px;
      max-width: 400px;
      margin: 40px auto 0;
    }
    .beta-input {
      width: 100%;
      height: 56px;
      padding: 0 20px;
      font-family: var(--font-body);
      font-size: 16px;
      color: var(--text-bright);
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid var(--border-light);
      border-radius: 8px;
      transition: border-color 0.2s ease, background 0.2s ease;
    }
    .beta-input::placeholder { color: var(--text-ghost); }
    .beta-input:focus {
      outline: none;
      border-color: var(--amber);
      background: rgba(255, 255, 255, 0.06);
    }
    .beta-submit {
      width: 100%;
      height: 56px;
      font-family: var(--font-label);
      font-size: 13px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--bg-deep);
      background: var(--amber);
      border: 0;
      border-radius: 8px;
      cursor: pointer;
      transition: background 0.2s ease, transform 0.1s ease;
    }
    .beta-submit:hover { background: var(--text-bright); }
    .beta-submit:active { transform: scale(0.99); }

    .beta-fine {
      font-family: var(--font-body);
      font-weight: 300;
      font-size: 13px;
      line-height: 1.6;
      color: var(--text-ghost);
      max-width: 400px;
      margin: 18px auto 0;
    }
    .beta-error { font-family: var(--font-label); font-size: 12px; letter-spacing: 0.06em; color: #c98a7a; margin: 14px 0 0; }
    .beta-done {
      font-family: 'Lora', Georgia, serif;
      font-style: italic;
      font-size: 18px;
      line-height: 1.5;
      color: var(--amber);
      margin: 16px 0 0;
    }
    /* On success, retire the form and let the confirmation stand alone. */
    .beta-card.is-done .beta-form,
    .beta-card.is-done .beta-fine { display: none; }

    .beta-foot {
      position: relative;
      font-family: var(--font-label);
      font-size: 11px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--text-ghost);
      margin: 64px 0 0;
    }
    .beta-foot a { color: var(--text-muted); text-decoration: none; border-bottom: 1px solid var(--border); }
    .beta-foot a:hover { color: var(--amber); }

    @media (max-width: 520px) {
      /* Instagram's in-app browser eats ~140px of top/bottom chrome. Anchor the
         content to the top so the lockup, headline, field and CTA all land on
         the first screen with no long gap to scroll past. */
      .beta { padding: 40px 22px; justify-content: flex-start; }
      .beta-glow { top: 34%; }
      .beta-lockup { margin-bottom: 30px; }
      .beta-form { margin-top: 32px; }
    }
  </style>
</Base>
