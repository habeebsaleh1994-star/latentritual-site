---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const rooms = [
  {
    number: '01',
    name: 'Studio',
    verb: 'Remember',
    body: 'Return to the work as a life already in motion: recent photographs, distant seasons, and the shape of years.',
  },
  {
    number: '02',
    name: 'Workbench',
    verb: 'Gather',
    body: 'Bring today’s attention together: new negatives, work waiting to be developed, recent edits, projects, and source volumes.',
  },
  {
    number: '03',
    name: 'Light Table',
    verb: 'Decide',
    body: 'Compare, rate, collect, narrow, and sequence. Selection is part of making the photograph, not housekeeping beside it.',
  },
  {
    number: '04',
    name: 'Darkroom',
    verb: 'Develop',
    body: 'Carry the photograph through Film, Light, Paper, and the final work of Retouch.',
  },
];

const retouchBenches = [
  {
    index: 'I',
    title: 'Repair',
    body: 'Spot, remove, mend, and clone with texture and tone that belong to the photograph around them.',
  },
  {
    index: 'II',
    title: 'Light & Tone',
    body: 'Shape local exposure, colour, contrast, atmosphere, and detail with brush, radial, gradient, subject, or depth.',
  },
  {
    index: 'III',
    title: 'Portrait',
    body: 'Work gently with skin, teeth, eyes, and lips through visible masks and photographic boundaries.',
  },
];

const storyFrames = [
  { src: '/develop-3-after-3840.webp', alt: 'A carousel turning beside an old stone wall' },
  { src: '/develop-6-after-3840.webp', alt: 'A man walking through late light and long shadows' },
  { src: '/develop-5-after-3840.webp', alt: 'A dog sleeping in a quiet village street' },
  { src: '/develop-2-after-3840.webp', alt: 'An ice cream vendor at dusk' },
];
---

<Base
  title="The Ritual — A complete photographic workroom"
  description="The Ritual is a complete photographic workroom for Mac and iPad, from archive and negative to retouch, story, and finished print."
  ogImageAlt="The Ritual — a complete photographic workroom for Mac and iPad"
>
  <Nav />

  <main id="main" class="ritual-page">
    <section class="ritual-hero" aria-labelledby="ritual-title">
      <div class="ritual-hero-image" aria-hidden="true"></div>
      <div class="ritual-hero-wash" aria-hidden="true"></div>

      <div class="ritual-hero-copy">
        <p class="ritual-kicker">The Ritual · Mac and iPad</p>
        <h1 id="ritual-title">A complete<br />photographic workroom.</h1>
        <p class="ritual-hero-body">
          Live with a body of work from the first import to the finished print.
          Remember it. Decide what matters. Develop the negative. Mend the
          light. Make the print. Send it out.
        </p>
        <a class="ritual-text-link" href="#rooms">Enter the workroom <span aria-hidden="true">↓</span></a>
      </div>

      <p class="ritual-hero-note">Develop, don’t correct.</p>
    </section>

    <section class="ritual-prologue" aria-labelledby="prologue-title">
      <p class="ritual-section-mark reveal">One working life</p>
      <h2 id="prologue-title" class="reveal reveal-heading">
        Not a catalog beside an editor.<br />One place to live with the work.
      </h2>
      <div class="ritual-prologue-copy reveal">
        <p>
          The Ritual begins before a photograph is opened and stays until the
          work is ready to leave. Originals, decisions, development, local
          work, prints, and sequences remain parts of the same practice.
        </p>
        <p>
          Nothing is corrected toward a generic ideal. The photograph is
          unfinished. The photographer brings it toward an intention.
        </p>
      </div>
    </section>

    <section class="ritual-rooms" id="rooms" aria-labelledby="rooms-title">
      <header class="ritual-section-head reveal">
        <p class="ritual-section-mark">The working rooms</p>
        <h2 id="rooms-title">The work changes.<br />The room changes with it.</h2>
      </header>

      <div class="rooms-map" aria-label="The four working rooms of The Ritual">
        {rooms.map((room, index) => (
          <article class="room-card reveal" style={`--reveal-delay: ${index * 90}ms`}>
            <div class="room-card-top">
              <span>{room.number}</span>
              <span>{room.verb}</span>
            </div>
            <div class="room-window" aria-hidden="true">
              <span class="room-window-name">{room.name}</span>
              <span class="room-window-light"></span>
            </div>
            <h3>{room.name}</h3>
            <p>{room.body}</p>
          </article>
        ))}
      </div>

      <p class="capture-note reveal">
        The four frames are reserved for one current release-candidate capture set:
        the same library, photograph, window, and day across every room.
      </p>
    </section>

    <section class="ritual-process" aria-labelledby="process-title">
      <div class="process-photo reveal" aria-hidden="true">
        <img src="/develop-4-after-3840.webp" alt="" width="3840" height="2560" loading="lazy" />
        <div class="process-photo-caption">One photograph · one continuous field</div>
      </div>

      <div class="process-copy">
        <p class="ritual-section-mark reveal">The Darkroom</p>
        <h2 id="process-title" class="reveal reveal-heading">Film. Light. Paper.</h2>
        <p class="process-lead reveal">
          Three material passages, held inside one developing photograph.
        </p>

        <ol class="process-list">
          <li class="reveal">
            <span class="process-number">01</span>
            <div>
              <h3>Film <small>Develop</small></h3>
              <p>Build the negative. Exposure, development, latitude, grain, halation, optics, and scan character behave as material—not as a look pasted on.</p>
            </div>
          </li>
          <li class="reveal" style="--reveal-delay: 80ms">
            <span class="process-number">02</span>
            <div>
              <h3>Light <small>Interpret</small></h3>
              <p>Bring forward what the negative carries. Tone, dye, detail, colour, and atmosphere remain connected rather than divided into isolated effects.</p>
            </div>
          </li>
          <li class="reveal" style="--reveal-delay: 160ms">
            <span class="process-number">03</span>
            <div>
              <h3>Paper <small>Realize</small></h3>
              <p>Give the photograph its final material response: density, grade, warmth, surface, wash, edge, and the light under which the print will live.</p>
            </div>
          </li>
        </ol>
      </div>
    </section>

    <section class="ritual-retouch" aria-labelledby="retouch-title">
      <div class="retouch-intro">
        <p class="ritual-section-mark reveal">Retouch · Mend</p>
        <h2 id="retouch-title" class="reveal reveal-heading">
          Retouch the negative,<br />not the surface.
        </h2>
        <p class="retouch-lead reveal">
          Repairs and local light become part of the development itself. Change
          the film, paper, grain, or density and every touch develops with it.
        </p>
      </div>

      <div class="retouch-photo reveal">
        <img
          src="/lab/portrait-1-colorplus-200-endura-metallic.webp"
          alt="A portrait developed with ColorPlus 200 and Endura Metallic"
          width="1600"
          height="900"
          loading="lazy"
        />
        <span>On the negative</span>
      </div>

      <div class="retouch-benches">
        {retouchBenches.map((bench, index) => (
          <article class="retouch-bench reveal" style={`--reveal-delay: ${index * 90}ms`}>
            <span>{bench.index}</span>
            <h3>{bench.title}</h3>
            <p>{bench.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="ritual-print" aria-labelledby="print-title">
      <div class="print-copy">
        <p class="ritual-section-mark reveal">The Print Room</p>
        <h2 id="print-title" class="reveal reveal-heading">Make the print.</h2>
        <p class="reveal">
          Strike a test strip. Balance the filters or split the grade. Preflash,
          dodge, burn, keep a work print, and make the final print under the
          light where it will be seen.
        </p>

        <div class="print-actions reveal" aria-label="Print Room instruments">
          <span>Test strip</span>
          <span>Filter pack</span>
          <span>Dodge &amp; burn</span>
          <span>Preflash</span>
          <span>Work prints</span>
        </div>
      </div>

      <figure class="paper-stage reveal">
        <div class="paper-mat">
          <img src="/develop-2-after-3840.webp" alt="A finished dusk photograph presented as a print" width="3840" height="2560" loading="lazy" />
        </div>
        <figcaption>Paper is where the photograph becomes final.</figcaption>
      </figure>
    </section>

    <section class="ritual-story" aria-labelledby="story-title">
      <header class="story-head">
        <p class="ritual-section-mark reveal">Light Table · Story</p>
        <h2 id="story-title" class="reveal reveal-heading">
          Finish the photograph.<br />Then finish the body of work.
        </h2>
        <p class="reveal">
          Move from selection into sequence. Form covers, pairs, spreads,
          pauses, and captions—then read the work as someone else will meet it.
        </p>
      </header>

      <div class="story-sequence" aria-label="A short sequence of four photographs">
        {storyFrames.map((frame, index) => (
          <figure class="story-frame reveal" style={`--reveal-delay: ${index * 80}ms`}>
            <img src={frame.src} alt={frame.alt} width="3840" height="2560" loading="lazy" />
            <figcaption>{String(index + 1).padStart(2, '0')}</figcaption>
          </figure>
        ))}
      </div>
    </section>

    <section class="ritual-trust" aria-labelledby="trust-title">
      <div class="trust-copy">
        <p class="ritual-section-mark reveal">Archive and Catalog Bridge</p>
        <h2 id="trust-title" class="reveal reveal-heading">The work remains yours.</h2>
        <p class="reveal">
          Originals, source volumes, catalog facts, and rendered previews stay
          in their proper places. Bring a Lightroom Classic catalog or Capture
          One catalog or session without changing the source.
        </p>
        <blockquote class="reveal">
          Your curation arrives.<br />Your photographs arrive as negatives.
        </blockquote>
      </div>

      <div class="bridge-receipt reveal" aria-label="Catalog Bridge principles">
        <div class="receipt-head">
          <span>The Catalog Bridge</span>
          <span>Read only</span>
        </div>
        <dl>
          <div><dt>Folders and collections</dt><dd>Carried</dd></div>
          <div><dt>Ratings and labels</dt><dd>Carried</dd></div>
          <div><dt>Keywords and captions</dt><dd>Carried</dd></div>
          <div><dt>Original locations</dt><dd>Preserved</dd></div>
          <div><dt>Source catalog</dt><dd>Untouched</dd></div>
          <div><dt>Proprietary edits</dt><dd>Left honestly behind</dd></div>
        </dl>
        <p>Every photograph accounted for.</p>
      </div>
    </section>

    <section class="ritual-surfaces" aria-labelledby="surfaces-title">
      <header class="surfaces-head">
        <p class="ritual-section-mark reveal">Mac and iPad</p>
        <h2 id="surfaces-title" class="reveal reveal-heading">
          The same Ritual,<br />wherever you sit with the work.
        </h2>
        <p class="reveal">
          Mac gives the work a room. iPad brings the same negative-to-print
          practice under your hands. Neither changes what the photograph can become.
        </p>
      </header>

      <div class="surface-pair reveal" aria-label="Reserved current product captures for Mac and iPad">
        <div class="surface-frame surface-mac">
          <div class="surface-bar"><span></span><span></span><span></span></div>
          <div class="surface-room">
            <span>Mac</span>
            <strong>Darkroom</strong>
            <small>Current capture after copy approval</small>
          </div>
        </div>
        <div class="surface-frame surface-ipad">
          <div class="surface-room">
            <span>iPad</span>
            <strong>The same negative</strong>
            <small>Current capture after copy approval</small>
          </div>
        </div>
      </div>
    </section>

    <section class="ritual-close" aria-labelledby="close-title">
      <p class="ritual-section-mark reveal">The Ritual</p>
      <h2 id="close-title" class="reveal reveal-heading">
        From first import<br />to the work you send out.
      </h2>
      <p class="reveal">
        One place to remember, decide, develop, mend, print, sequence, and finish.
      </p>
      <a class="ritual-button reveal" href="#notify">Keep in touch</a>
    </section>
  </main>

  <Footer />
</Base>

<style>
  .ritual-page {
    --ritual-paper: #f0e7d9;
    --ritual-ink: #171311;
    --ritual-red: #8e2f22;
    background: var(--bg-deep);
  }

  .ritual-page :global(.ritual-section-mark) {
    margin: 0 0 26px;
    font-family: var(--font-label);
    font-size: 10px;
    font-weight: 300;
    line-height: 1.4;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--amber-dim);
  }

  .ritual-page :global(h2) {
    font-family: var(--font-display);
    font-size: clamp(42px, 6.2vw, 84px);
    font-weight: 250;
    line-height: 1.02;
    letter-spacing: -0.035em;
    color: var(--text-bright);
  }

  .ritual-hero {
    position: relative;
    width: 100%;
    max-width: none;
    min-height: 100svh;
    margin: 0;
    padding: 140px 6vw 72px;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    isolation: isolate;
  }

  .ritual-hero-image,
  .ritual-hero-wash {
    position: absolute;
    inset: 0;
  }

  .ritual-hero-image {
    z-index: -3;
    background-image: url('/develop-6-after-5120.jpg');
    background-size: cover;
    background-position: center 48%;
    transform: scale(1.025);
    animation: ritual-drift 24s ease-in-out infinite alternate;
  }

  .ritual-hero-wash {
    z-index: -2;
    background:
      linear-gradient(90deg, rgba(12, 10, 9, 0.9) 0%, rgba(12, 10, 9, 0.58) 46%, rgba(12, 10, 9, 0.08) 76%),
      linear-gradient(0deg, rgba(12, 10, 9, 0.75) 0%, transparent 52%, rgba(12, 10, 9, 0.3) 100%);
  }

  @keyframes ritual-drift {
    from { transform: scale(1.025) translate3d(0, 0, 0); }
    to { transform: scale(1.06) translate3d(-0.8%, -0.4%, 0); }
  }

  .ritual-hero-copy {
    width: min(840px, 92vw);
    padding-bottom: 4vh;
  }

  .ritual-kicker {
    margin-bottom: 30px;
    font-family: var(--font-label);
    font-size: 10px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--amber);
    opacity: 0;
    animation: ritual-rise 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.15s forwards;
  }

  .ritual-hero h1 {
    max-width: 840px;
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(54px, 8.4vw, 116px);
    font-weight: 220;
    line-height: 0.94;
    letter-spacing: -0.052em;
    color: #f5ede2;
    text-shadow: 0 6px 50px rgba(0, 0, 0, 0.35);
    opacity: 0;
    animation: ritual-rise 1.4s cubic-bezier(0.16, 1, 0.3, 1) 0.3s forwards;
  }

  .ritual-hero-body {
    max-width: 670px;
    margin: 38px 0 0;
    font-size: clamp(18px, 2vw, 24px);
    font-weight: 300;
    line-height: 1.55;
    color: rgba(240, 231, 217, 0.82);
    opacity: 0;
    animation: ritual-rise 1.4s cubic-bezier(0.16, 1, 0.3, 1) 0.5s forwards;
  }

  .ritual-text-link {
    display: inline-flex;
    gap: 12px;
    margin-top: 40px;
    font-family: var(--font-label);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--amber);
    text-decoration: none;
    opacity: 0;
    animation: ritual-rise 1.4s cubic-bezier(0.16, 1, 0.3, 1) 0.68s forwards;
  }

  .ritual-hero-note {
    position: absolute;
    right: 6vw;
    bottom: 72px;
    margin: 0;
    writing-mode: vertical-rl;
    font-family: var(--font-label);
    font-size: 9px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: rgba(240, 231, 217, 0.55);
  }

  @keyframes ritual-rise {
    from { opacity: 0; transform: translateY(22px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .ritual-prologue {
    max-width: 1240px;
    padding-top: 220px;
    padding-bottom: 220px;
  }

  .ritual-prologue h2 {
    max-width: 1050px;
  }

  .ritual-prologue-copy {
    max-width: 770px;
    margin: 80px 0 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 54px;
    font-size: 18px;
    line-height: 1.75;
    color: var(--text-muted);
  }

  .ritual-rooms {
    max-width: none;
    padding: 180px max(24px, 5vw);
    background: #171311;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .ritual-section-head {
    max-width: 1280px;
    margin: 0 auto 92px;
  }

  .rooms-map {
    max-width: 1500px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }

  .room-card {
    min-width: 0;
    padding: 22px 22px 36px;
    background: var(--bg-deep);
  }

  .room-card-top {
    display: flex;
    justify-content: space-between;
    margin-bottom: 38px;
    font-family: var(--font-label);
    font-size: 8px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-ghost);
  }

  .room-window {
    position: relative;
    aspect-ratio: 4 / 3;
    margin-bottom: 34px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border: 1px solid #2f2824;
    background:
      linear-gradient(90deg, #171311 0 14%, transparent 14% 78%, #171311 78%),
      linear-gradient(#201a17 0 12%, #0e0c0b 12% 78%, #171311 78%);
  }

  .room-window::before {
    content: '';
    position: absolute;
    inset: 26% 18% 14%;
    background-image: url('/develop-6-after.webp');
    background-size: cover;
    background-position: center;
    opacity: 0.72;
  }

  .room-card:nth-child(2) .room-window::before { background-image: url('/develop-5-after.webp'); }
  .room-card:nth-child(3) .room-window::before { background-image: url('/develop-3-after.webp'); }
  .room-card:nth-child(4) .room-window::before { background-image: url('/develop-4-after.webp'); }

  .room-window-name {
    position: absolute;
    top: 9px;
    left: 12px;
    z-index: 2;
    font-family: var(--font-label);
    font-size: 6px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-ghost);
  }

  .room-window-light {
    position: absolute;
    inset: 30% 22% 18%;
    z-index: 1;
    box-shadow: 0 0 42px rgba(232, 196, 160, 0.12);
  }

  .room-card h3 {
    margin: 0 0 14px;
    font-size: 25px;
    font-weight: 300;
    color: var(--text-bright);
  }

  .room-card p {
    margin: 0;
    font-size: 15px;
    line-height: 1.65;
    color: var(--text-muted);
  }

  .capture-note {
    max-width: 720px;
    margin: 42px auto 0;
    text-align: center;
    font-family: var(--font-label);
    font-size: 9px;
    line-height: 1.7;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-ghost);
  }

  .ritual-process {
    max-width: 1600px;
    padding-top: 220px;
    padding-bottom: 220px;
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(420px, 0.85fr);
    gap: clamp(70px, 9vw, 150px);
    align-items: center;
  }

  .process-photo {
    position: relative;
    min-height: 760px;
    overflow: hidden;
    background: #0b0908;
    box-shadow: 0 60px 120px rgba(0, 0, 0, 0.48);
  }

  .process-photo img {
    width: 100%;
    height: 100%;
    min-height: 760px;
    object-fit: cover;
    object-position: 52% center;
  }

  .process-photo-caption {
    position: absolute;
    left: 24px;
    bottom: 20px;
    font-family: var(--font-label);
    font-size: 8px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(240, 231, 217, 0.6);
  }

  .process-copy h2 { margin-bottom: 24px; }

  .process-lead {
    max-width: 500px;
    font-size: 20px;
    line-height: 1.55;
    color: var(--text-muted);
  }

  .process-list {
    margin-top: 70px;
    list-style: none;
  }

  .process-list li {
    display: grid;
    grid-template-columns: 42px 1fr;
    gap: 20px;
    padding: 30px 0;
    border-top: 1px solid var(--border);
  }

  .process-number {
    padding-top: 5px;
    font-family: var(--font-label);
    font-size: 9px;
    letter-spacing: 0.16em;
    color: var(--amber-dim);
  }

  .process-list h3 {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin: 0 0 12px;
    font-size: 27px;
    font-weight: 300;
    color: var(--text-bright);
  }

  .process-list h3 small {
    font-family: var(--font-label);
    font-size: 8px;
    font-weight: 300;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-ghost);
  }

  .process-list p {
    margin: 0;
    font-size: 15px;
    line-height: 1.7;
    color: var(--text-muted);
  }

  .ritual-retouch {
    max-width: none;
    padding: 210px max(24px, 7vw);
    background: var(--ritual-paper);
    color: var(--ritual-ink);
  }

  .retouch-intro {
    max-width: 1240px;
    margin: 0 auto 90px;
  }

  .ritual-retouch .ritual-section-mark { color: #8b6451; }
  .ritual-retouch h2 { color: var(--ritual-ink); }

  .retouch-lead {
    max-width: 650px;
    margin: 44px 0 0 auto;
    font-size: 20px;
    line-height: 1.65;
    color: #6f625a;
  }

  .retouch-photo {
    position: relative;
    max-width: 1240px;
    margin: 0 auto;
    aspect-ratio: 16 / 8.5;
    overflow: hidden;
    background: #c7bcad;
  }

  .retouch-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .retouch-photo span {
    position: absolute;
    left: 26px;
    bottom: 22px;
    padding: 8px 11px;
    font-family: var(--font-label);
    font-size: 8px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #f2e8da;
    background: rgba(20, 16, 14, 0.68);
  }

  .retouch-benches {
    max-width: 1240px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
  }

  .retouch-bench {
