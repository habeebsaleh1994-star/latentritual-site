---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

// Buttondown embed endpoint (Settings → Embedding → <form action>).
const BUTTONDOWN_ACTION = 'https://buttondown.com/api/emails/embed-subscribe/habeebsaleh1994';

// The six parameter pages, in the order the engine works the frame —
// negative first, then the print, then the surface, fall-off, texture, output.
// (Mirrors describeInContext in LatentOFXPlugin.cpp.)
const pipeline = [
  { n: '01', name: 'Color', body: 'Tag the working space (ACES, DaVinci Wide Gamut or Rec.709) or ingest camera log straight from ARRI, Sony, RED, Blackmagic or Apple Log, so the engine develops in the right math. Output to Rec.709, DWG, ACES, P3 or Rec.2020, with diagnostic views at each step.', controls: ['Managed or camera-log in', '10 camera profiles', 'Diagnostic views'] },
  { n: '02', name: 'Lens / Bloom', body: 'Optical diffusion before the film even sees the light, mist, bloom and veil, thresholded in EV so only the highlights flower.', controls: ['Mist · Bloom · Veil', 'Highlight threshold'] },
  { n: '03', name: 'Negative', body: 'Pick a process (C-41, ECN-2 cinema, reversal or B&W silver), then the stock within it. Expose, push or pull, even bleach-bypass.', controls: ['4 processes · 47 stocks', 'Exposure · Push/Pull', 'Bleach bypass'] },
  { n: '04', name: 'Process Path', body: 'Print onto the right medium: RA-4 color paper, a cinema release print, a slide view, or silver gelatin, with darkroom toning on B&W.', controls: ['Color · cinema · slide · silver', 'Sepia · selenium · gold · copper', 'Print exposure · grade'] },
  { n: '05', name: 'Print Response', body: 'The enlarger head: density, grade, dichroic yellow/magenta filtering, preflash and split-grade, plus dye response and a three-zone color wash.', controls: ['Dichroic filters · preflash', 'Split-grade', 'Dye response · color wash'] },
  { n: '06', name: 'Scan', body: 'Digitize it the way a lab would (Noritsu, Frontier, Pakon, flatbed, DSLR, a clean DI, or a Cintel / Spirit telecine), each with its own character.', controls: ['8 scanner & telecine looks', 'Sharpness · lens blur', 'White / black correction'] },
  { n: '07', name: 'Edge & Detail', body: 'Burn the edges down like an enlarger, and shape acutance, coarse and fine detail, size and edge balance.', controls: ['Edge burn · vignette', 'Acutance · fine detail'] },
  { n: '08', name: 'Texture', body: 'A real halation model and a grain engine that actually moves, size, film format, organic structure, plus motion and boil so grain lives frame to frame. And a dust pass: specks, hairs, scratches and gate dirt, seeded so they move like a real print.', controls: ['Halation model', 'Animated grain · boil', 'Dust · scratches · gate dirt'] },
  { n: '09', name: 'Film Transport', body: 'The mechanical life of film through a gate, weave, flicker and breathing, on a chosen gate plate, so motion feels projected, not pristine.', controls: ['Gate weave · breathing', 'Flicker · speed', 'Gate plate'] },
];

// Stocks grouped by development family — mirrors the catalog the plugin ships
// (LatentOFXStockCatalog.generated.h): 47 selectable stocks across 4 processes.
const stockGroups = [
  { label: 'Color negative', items: ['Portra 400', 'Ektar 100', 'Portra 160', 'Portra 800', 'Gold 200', 'ColorPlus 200', 'Pro Image 100', 'Fuji Pro 400H', 'Superia 400', 'Pro 800Z', 'Superia Reala', 'CineStill 800T', 'CineStill 400D', 'Ultramax 400', 'Agfa Vista 400', 'Agfa Vista 100', 'Agfa Vista 800', 'Agfa Ultra 100', 'Agfa Portrait 160', 'Agfa Optima 400', 'Agfa Optima II 400', 'Royal Gold 100', 'Fuji Pro 160S', 'Fujifilm 200', 'Konica Pro 160', 'Portra 400 VC'] },
  { label: 'Motion · ECN-2', items: ['Vision3 500T', 'Vision3 250D', 'Vision3 50D', 'Vision3 200T', 'Vision2 Express 500T'] },
  { label: 'Reversal', items: ['Velvia 50', 'Provia 100F', 'Ektachrome E100', 'Kodachrome 64', 'Provia 400X', 'Provia 400F', 'Astia 100F', 'Ektachrome 100 EPN', 'Ektachrome 100D'] },
  { label: 'Black & white', items: ['Tri-X 400', 'HP5 Plus', 'T-MAX 400', 'Acros 100', 'Delta 3200', 'Pan F Plus 50', 'FP4 Plus'] },
];
const stockTotal = stockGroups.reduce((sum, g) => sum + g.items.length, 0);

// The view path follows the stock — the real conditional behaviour in the plugin.
const viewPaths = [
  { from: 'Color negative', to: 'RA-4 paper', detail: '12 papers, Portra & Supra Endura, Fuji Crystal Archive & Supreme, Ektacolor, Endura Metallic…' },
  { from: 'Motion stock', to: 'Print film', detail: '5 looks, Kodak 2383 & 2393, Agfa CP30, Fuji ETERNA-CP, plus a straight ECN-2 scan.' },
  { from: 'Reversal', to: 'Transparency', detail: '5 views, lightbox, Ilfochrome Classic CLM / CPS, and two cross-processed RA-4 looks (E100 / K64).' },
  { from: 'Black & white', to: 'Silver gelatin', detail: '9 papers, Ilford Multigrade IV RC & FB, Foma Fomatone, Forte Polywarmtone, plus sepia, selenium, gold & copper toning.' },
];

const specs = [
  { k: 'Runs on Metal', v: 'A GPU pipeline built for real-time playback, not a bake-and-wait filter.' },
  { k: 'Speaks ACES', v: 'Tag your source (DaVinci Wide Gamut, ACEScct, ACEScg, Rec.709) or ingest camera log straight from ARRI, Sony, RED, Blackmagic or Apple Log, and the engine develops in the right space.' },
  { k: 'Lives on the color page', v: 'OpenFX → Filters → Film Emulation → Latent Print Engine. Drop it on a clip or an adjustment layer.' },
  { k: 'One engine, three apps', v: 'The same negative-to-print core as the Ritual on Mac and the Moment on iPhone, now on your timeline.' },
];

// Lab sample switcher: each frame carries its own list of looks.
// looks[0] is the developed look (shown by default + used as the thumbnail);
// the switcher preserves the selected look BY NAME across frames, so "RAW"
// (shared by every frame) holds while you click between frames.
const frames = [
  {
    name: 'Portrait 1',
    looks: [
      { name: 'Vision3 200T + 2393 Print', img: '/lab/portrait-1-vision3-200t-2393.webp' },
      { name: 'Kodak ColorPlus 200 + Kodak Endura Metallic Print', img: '/lab/portrait-1-colorplus-200-endura-metallic.webp' },
      { name: 'Kodak Tri-X 400 + Forte Polywarmtone Print', img: '/lab/portrait-1-trix-400-forte-polywarmtone.webp' },
      { name: 'RAW', img: '/lab/portrait-1-raw.webp' },
    ],
  },
  {
    name: 'Garden 1',
    looks: [
      { name: 'Vision3 250D + Fuji Eterna-CP Print', img: '/lab/garden-1-vision3-250d-fuji-eterna.webp' },
      { name: 'Ektar 100 + Kodak Portra Endura Print', img: '/lab/garden-1-ektar-100-portra-endura.webp' },
      { name: 'Fuji Superia Reala + Fuji Crystal Archive Supremer Print', img: '/lab/garden-1-reala-crystal-archive.webp' },
      { name: 'RAW', img: '/lab/garden-1-raw.webp' },
    ],
  },
  {
    name: 'Portrait 2',
    looks: [
      { name: 'Vision3 50D + Kodak 2383 Print', img: '/lab/portrait-2-vision3-50d-2383.webp' },
      { name: 'Fuji Provia 400F + Lightbox Scan', img: '/lab/portrait-2-provia-400f-lightbox.webp' },
      { name: 'Portra 400 + Kodak Supra Endura Print', img: '/lab/portrait-2-portra-400-supra-endura.webp' },
      { name: 'RAW', img: '/lab/portrait-2-raw.webp' },
    ],
  },
];
---

<Base
  title="The Lab — Latent for DaVinci Resolve"
  description="Latent's film engine, brought to DaVinci Resolve, 47 stocks across C-41, ECN-2, reversal and black-and-white; darkroom papers and toners; lens bloom, halation, an animated grain engine, lab and telecine scanners, and film-transport weave and flicker. Developed on the GPU, frame by frame. In development."
  ogImage="/og-resolve.png?v=2"
  ogImageAlt="The Lab — Latent for DaVinci Resolve"
>
  <Nav />
  <main class="rpage" id="main">

    <!-- HERO -->
    <section class="rs-hero">
      <div class="rs-kicker reveal">Latent · for DaVinci Resolve</div>
      <h1 class="rs-title reveal reveal-heading" style="--reveal-delay: 80ms">The Lab</h1>
      <p class="rs-tagline reveal" style="--reveal-delay: 200ms">Develop the negative. Print the frame. Inside Resolve.</p>
      <p class="rs-lead reveal" style="--reveal-delay: 300ms">
        Latent develops a photograph the way a darkroom does: it builds a negative and prints it onto
        paper. The Lab does the same to motion: every frame of your timeline, on the GPU,
        in real time.
      </p>
      <div class="rs-hero-actions reveal" style="--reveal-delay: 400ms">
        <a class="rs-btn" href="#notify">Join the waitlist</a>
        <a class="rs-btn rs-btn-ghost" href="#inside">See what's inside</a>
      </div>
      <div class="rs-status reveal" style="--reveal-delay: 480ms">
        <span class="rs-dot"></span> In development, coming to DaVinci Resolve
      </div>
    </section>

    <!-- HERO REEL — full-bleed cinematic, cuts graded with Latent -->
    <section class="rs-reel-wrap">
      <figure class="rs-reel reveal">
        <video class="rs-reel-video" autoplay muted loop playsinline preload="auto" poster="/resolve-reel-poster.jpg?v=3">
          <source src="/resolve-reel.webm?v=3" type="video/webm" />
          <source src="/resolve-reel-hevc.mp4?v=2" type='video/mp4; codecs="hvc1.1.6.L120.B0"' />
          <source src="/resolve-reel.mp4?v=4" type="video/mp4" />
        </video>
      </figure>
      <p class="rs-reel-cap">Graded in DaVinci Resolve with Latent</p>
    </section>

    <!-- SCENE × STOCK SWITCHER -->
    <section class="rs-switch-wrap">
      <div class="section-label reveal">Same frame, redeveloped</div>
      <h2 class="rs-h2 reveal reveal-heading" style="--reveal-delay: 80ms">See the film, not just a slider.</h2>
      <p class="rs-section-lead rs-switch-lead reveal" style="--reveal-delay: 140ms">Each frame is developed through a different film. Click RAW to see the decoded source it came from. Pick a frame below; hold RAW and step between them to watch what the engine adds.</p>
      <div class="rs-switch reveal" style="--reveal-delay: 200ms" data-switch>
        <div class="rs-switch-frame">
          {frames.map((fr, fi) => fr.looks.map((lk, li) => (
            <img class:list={["rs-switch-img", fi === 0 && li === 0 && "is-active"]} data-frame={fi} data-look={li} src={lk.img} alt={`${fr.name}, ${lk.name}`} loading="lazy" />
          )))}
          <div class="rs-switch-cap"><span data-cap-look>{frames[0].looks[0].name}</span></div>
        </div>
        <div class="rs-switch-stocks">
          {frames.map((fr, fi) => (
            <div class:list={["rs-switch-group", fi === 0 && "is-active"]} data-stock-group={fi}>
              {fr.looks.map((lk, li) => (
                <button class:list={["rs-switch-stock", li === 0 && "is-active"]} data-frame={fi} data-look={li}>{lk.name}</button>
              ))}
            </div>
          ))}
        </div>
      </div>
      {frames.length > 1 && (
        <div class="rs-switch-thumbs reveal" style="--reveal-delay: 260ms">
          {frames.map((fr, fi) => (
            <button class:list={["rs-switch-thumb", fi === 0 && "is-active"]} data-frame-btn={fi} aria-label={fr.name}>
              <img src={fr.looks[0].img} alt={fr.name} loading="lazy" />
            </button>
          ))}
        </div>
      )}
    </section>

    <!-- ONE NODE · COLOR MANAGED -->
    <section class="rs-node">
      <div class="section-label reveal">Color-managed · one node</div>
      <h2 class="rs-h2 reveal reveal-heading" style="--reveal-delay: 80ms">The whole lab, in a single node.</h2>
      <p class="rs-section-lead rs-node-lead reveal" style="--reveal-delay: 160ms">
        No node tree, no LUT juggling. Decode your RAW or log to a supported camera log and gamut, choose
        the matching Camera Profile, and Latent carries it through: negative, print, scan, texture. Then it
        hands back the delivery space you need.
      </p>
      <div class="rs-flow reveal" style="--reveal-delay: 240ms">
        <div class="rs-flow-step">
          <div class="rs-flow-k">In</div>
          <div class="rs-flow-v">Camera log + gamut<br />matching Camera Profile</div>
        </div>
        <span class="rs-flow-arrow">&#8594;</span>
        <div class="rs-flow-step rs-flow-engine">
          <div class="rs-flow-k">Latent</div>
          <div class="rs-flow-v">negative · print · scan · texture</div>
        </div>
        <span class="rs-flow-arrow">&#8594;</span>
        <div class="rs-flow-step">
          <div class="rs-flow-k">Out</div>
          <div class="rs-flow-v">Rec.709-A · Rec.709 2.4<br />DWG · ACES · P3</div>
        </div>
      </div>
      <p class="rs-node-foot reveal" style="--reveal-delay: 320ms">All inside one OpenFX node.</p>
    </section>

    <!-- PIPELINE -->
    <section class="rs-pipeline" id="inside">
      <div class="section-label reveal">The path · lens to projector</div>
      <h2 class="rs-h2 reveal reveal-heading" style="--reveal-delay: 80ms">Nine stations, lens to projector.</h2>
      <div class="rs-stages">
        {pipeline.map((s, i) => (
          <div class="rs-stage reveal" style={`--reveal-delay: ${i * 70}ms`}>
            <div class="rs-stage-n">{s.n}</div>
            <div class="rs-stage-name">{s.name}</div>
            <p class="rs-stage-body">{s.body}</p>
            <ul class="rs-stage-controls">
              {s.controls.map((c) => <li>{c}</li>)}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <!-- STOCKS -->
    <section class="rs-catalog">
      <div class="section-label reveal">The negative · {stockTotal} film stocks</div>
      <h2 class="rs-h2 reveal reveal-heading" style="--reveal-delay: 80ms">The same emulsions, profiled spectrally.</h2>
      <div class="rs-stock-groups">
        {stockGroups.map((g, i) => (
          <div class="rs-stock-group reveal" style={`--reveal-delay: ${i * 70}ms`}>
            <div class="rs-stock-head"><span>{g.label}</span><span class="rs-stock-count">{g.items.length}</span></div>
            <ul class="rs-stock-list">
              {g.items.map((it) => <li>{it}</li>)}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <!-- VIEW PATH -->
    <section class="rs-viewpath">
      <div class="section-label reveal">The print · it knows your stock</div>
      <h2 class="rs-h2 reveal reveal-heading" style="--reveal-delay: 80ms">You don't print Tri-X on color paper.</h2>
      <p class="rs-section-lead reveal" style="--reveal-delay: 160ms">
        Choose a stock and the View Path follows it. A color negative offers RA-4 papers; a black-and-white
        stock offers silver gelatin; motion film prints to release stock; reversal stays transparent.
      </p>
      <div class="rs-paths">
        {viewPaths.map((p, i) => (
          <div class="rs-path reveal" style={`--reveal-delay: ${i * 70}ms`}>
            <div class="rs-path-row">
              <span class="rs-path-from">{p.from}</span>
              <span class="rs-path-arrow">→</span>
              <span class="rs-path-to">{p.to}</span>
            </div>
            <p class="rs-path-detail">{p.detail}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- TECH -->
    <section class="rs-tech">
      <div class="section-label reveal">Built for the timeline</div>
      <div class="rs-specs">
        {specs.map((s, i) => (
          <div class="rs-spec reveal" style={`--reveal-delay: ${i * 70}ms`}>
            <div class="rs-spec-k">{s.k}</div>
            <p class="rs-spec-v">{s.v}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- PRICING -->
    <section class="rs-pricing" id="pricing">
      <div class="section-label reveal">Pricing</div>
      <h2 class="rs-h2 reveal reveal-heading" style="--reveal-delay: 80ms">The Lab for DaVinci Resolve.</h2>
      <div class="rs-price-box reveal" style="--reveal-delay: 160ms">
        <div>
          <div class="rs-price-label">Annual</div>
          <div class="rs-price-amount">$199</div>
          <div class="rs-price-unit">per year</div>
        </div>
        <div>
          <div class="rs-price-label">Perpetual</div>
          <div class="rs-price-amount">$499</div>
          <div class="rs-price-unit">one-time purchase</div>
        </div>
        <div class="rs-price-copy">
          <p>Both include the Latent OFX plugin and a one-person license, for personal or commercial work alike.</p>
          <p>The annual plan includes updates while the subscription is active. The perpetual license includes all 1.x updates.</p>
          <p>The Lab is still in development. When checkout opens, it runs through Paddle.</p>
          <p class="rs-price-note">Latent apps for Mac, iPad, and iPhone are sold separately through Apple's App Store.</p>
        </div>
      </div>
    </section>

    <!-- WAITLIST -->
    <section class="rs-notify" id="notify" data-newsletter>
      <h2 class="rs-h2 reveal reveal-heading">It isn't finished yet.</h2>
      <p class="rs-notify-line reveal" style="--reveal-delay: 80ms">
        I'm building the Print Engine now, in Joun. Leave your email and I'll write you the day it's
        ready to drop into Resolve, nothing else.
      </p>
      <form
        class="rs-form reveal"
        style="--reveal-delay: 160ms"
        action={BUTTONDOWN_ACTION}
        method="post"
        target="_blank"
        data-newsletter-form
      >
        <label class="visually-hidden" for="rs-email">Email address</label>
        <input type="hidden" name="metadata__source" value="resolve" />
        <input
          id="rs-email"
          class="rs-input"
          type="email"
          name="email"
          required
          autocomplete="email"
          placeholder="your email"
        />
        <button type="submit" class="rs-submit">Notify me</button>
      </form>
      <p class="rs-form-error" data-newsletter-error hidden role="alert">That email doesn't look right.</p>
      <p class="rs-form-done" data-newsletter-done hidden role="status" aria-live="polite">
        You're on the list. I'll be in touch the day it ships.
      </p>
    </section>

  </main>
  <Footer />

  <style>
    /* The Lab — Latent for DaVinci Resolve.
       Dark like the Ritual (the colorist's suite is dark, and this IS the
       Ritual's engine), but with its own cool accent — a film/cinema teal,
       opposite-temperature from the Ritual's amber and the Moment's terracotta.
       The accent lives in --rs and is used sparingly: eyebrows, the engine
       numbers, the print arrows, the CTA. */
    .rpage {
      --rs: #6fb7ae;
      --rs-dim: #4f8a83;
      --rs-faint: rgba(111, 183, 174, 0.10);
    }

    /* Tint every section eyebrow with the teal accent. */
    .rpage .section-label { color: var(--rs); }

    /* ── HERO ── */
    .rs-hero {
      max-width: 860px;
      padding: 172px 24px 86px;
      text-align: center;
    }
    .rs-kicker {
      font-family: var(--font-label);
      font-size: 11px;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--rs);
      margin-bottom: 26px;
    }
    .rs-title {
      font-family: var(--font-display);
      font-weight: 300;
      font-size: clamp(46px, 9.5vw, 86px);
      line-height: 1;
      letter-spacing: -0.02em;
      color: var(--text-bright);
      margin-bottom: 22px;
    }
    .rs-tagline {
      font-family: var(--font-display);
      font-weight: 300;
      font-size: clamp(19px, 3.2vw, 27px);
      line-height: 1.3;
      color: var(--text);
      margin-bottom: 26px;
    }
    .rs-lead {
      font-size: 17px;
      line-height: 1.7;
      color: var(--text-muted);
      max-width: 600px;
      margin: 0 auto 40px;
    }
    .rs-hero-actions {
      display: flex;
      gap: 14px;
      justify-content: center;
      flex-wrap: wrap;
      margin-bottom: 30px;
    }
    .rs-btn {
      font-family: var(--font-label);
      font-size: 11px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--bg-deep);
      background: var(--rs);
      border: 1px solid var(--rs);
      padding: 13px 26px;
      border-radius: 2px;
      text-decoration: none;
      transition: background 0.3s ease, color 0.3s ease, border-color 0.3s ease;
    }
    .rs-btn:hover { background: transparent; color: var(--rs); }
    .rs-btn-ghost { background: transparent; color: var(--text); border-color: var(--border-light); }
    .rs-btn-ghost:hover { color: var(--rs); border-color: var(--rs); }
    .rs-status {
      font-family: var(--font-label);
      font-size: 11px;
      letter-spacing: 0.12em;
      color: var(--text-muted);
      display: inline-flex;
      align-items: center;
      gap: 9px;
    }
    .rs-dot {
      width: 7px; height: 7px;
      border-radius: 50%;
      background: var(--rs);
      animation: rs-pulse 2.8s ease-out infinite;
    }
    @keyframes rs-pulse {
      0%   { box-shadow: 0 0 0 0 rgba(111, 183, 174, 0.45); }
      70%  { box-shadow: 0 0 0 9px rgba(111, 183, 174, 0); }
      100% { box-shadow: 0 0 0 0 rgba(111, 183, 174, 0); }
    }

    /* ── HERO REEL (full-bleed cinematic, cuts graded with Latent) ── */
    .rs-reel-wrap { padding: 8px 24px 110px; }
    .rs-reel {
      position: relative;
      left: 50%;
      right: 50%;
      width: 100vw;
      margin: 0 -50vw;
      overflow: hidden;
      background: var(--bg-deep);
      box-shadow: 0 50px 120px rgba(0, 0, 0, 0.6);
    }
    .rs-reel-video {
      display: block;
      width: 100%;
      aspect-ratio: 16 / 9;
      max-height: 86vh;
      object-fit: cover;
      background: var(--bg-deep);
    }
    .rs-reel-cap {
      font-family: var(--font-label);
      font-size: 11px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--text-muted);
      text-align: center;
      margin: 18px auto 0;
    }

    /* ── SHARED HEADING ── */
    .rs-h2 {
      font-family: var(--font-display);
      font-weight: 300;
      font-size: clamp(26px, 4.5vw, 38px);
      line-height: 1.2;
      letter-spacing: -0.01em;
      color: var(--text-bright);
      margin-top: 14px;
    }
    .rs-section-lead {
      font-size: 16px;
      line-height: 1.7;
      color: var(--text-muted);
      max-width: 620px;
      margin-top: 18px;
    }

    /* ── PIPELINE ── */
    .rs-pipeline { max-width: 1100px; }
    .rs-stages {
      margin-top: 56px;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background: var(--border);
      border: 1px solid var(--border);
      border-radius: 4px;
      overflow: hidden;
    }
    .rs-stage { background: var(--bg); padding: 30px 26px 32px; }
    .rs-stage-n {
      font-family: var(--font-label);
      font-size: 11px;
      letter-spacing: 0.2em;
      color: var(--rs);
      margin-bottom: 14px;
    }
    .rs-stage-name {
      font-family: var(--font-display);
      font-weight: 400;
      font-size: 19px;
      color: var(--text-bright);
      margin-bottom: 10px;
    }
    .rs-stage-body { font-size: 14px; line-height: 1.6; color: var(--text-muted); margin-bottom: 16px; }
    .rs-stage-controls { list-style: none; display: flex; flex-direction: column; gap: 6px; }
    .rs-stage-controls li {
      font-family: var(--font-label);
      font-size: 11px;
      letter-spacing: 0.03em;
      color: var(--text);
      padding-left: 14px;
      position: relative;
    }
    .rs-stage-controls li::before { content: '·'; position: absolute; left: 2px; color: var(--rs); }

    /* ── STOCKS ── */
    .rs-catalog { max-width: 1100px; }
    .rs-stock-groups {
      margin-top: 56px;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 36px;
    }
    .rs-stock-head {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      border-bottom: 1px solid var(--border-light);
      padding-bottom: 10px;
      margin-bottom: 16px;
      font-family: var(--font-label);
      font-size: 11px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--text);
    }
    .rs-stock-count { color: var(--rs); }
    .rs-stock-list { list-style: none; display: flex; flex-direction: column; gap: 9px; }
    .rs-stock-list li { font-size: 14px; color: var(--text-muted); }

    /* ── VIEW PATH ── */
    .rs-viewpath { max-width: 920px; }
    .rs-paths {
      margin-top: 48px;
      display: grid;
      gap: 1px;
      background: var(--border);
      border: 1px solid var(--border);
      border-radius: 4px;
      overflow: hidden;
    }
    .rs-path { background: var(--bg); padding: 22px 28px; }
    .rs-path-row { display: flex; align-items: center; gap: 14px; }
    .rs-path-from {
      font-family: var(--font-display);
      font-weight: 400;
      font-size: 16px;
      color: var(--text-bright);
      min-width: 140px;
    }
    .rs-path-arrow { color: var(--rs); }
    .rs-path-to {
      font-family: var(--font-display);
      font-weight: 400;
      font-size: 16px;
      color: var(--rs);
    }
    .rs-path-detail { font-size: 13px; line-height: 1.6; color: var(--text-muted); margin-top: 8px; }

    /* ── TECH ── */
    .rs-tech { max-width: 1000px; }
    .rs-specs {
      margin-top: 40px;
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1px;
      background: var(--border);
      border: 1px solid var(--border);
      border-radius: 4px;
      overflow: hidden;
    }
    .rs-spec { background: var(--bg); padding: 34px 32px; }
    .rs-spec-k {
      font-family: var(--font-display);
      font-weight: 400;
      font-size: 18px;
      color: var(--text-bright);
      margin-bottom: 10px;
    }
    .rs-spec-v { font-size: 14px; line-height: 1.65; color: var(--text-muted); }

    /* ── PRICING ── */
    .rs-pricing { max-width: 860px; }
    .rs-price-box {
      margin-top: 42px;
      display: grid;
      grid-template-columns: 210px 210px 1fr;
      gap: 1px;
      background: var(--border);
      border: 1px solid var(--border);
      border-radius: 4px;
      overflow: hidden;
    }
    .rs-price-box > div { background: var(--bg); padding: 34px 32px; }
    .rs-price-label {
      font-family: var(--font-label);
      font-size: 10px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--rs);
      margin-bottom: 14px;
    }
    .rs-price-amount {
      font-family: var(--font-display);
      font-weight: 300;
      font-size: 52px;
      line-height: 1;
      color: var(--text-bright);
      margin-bottom: 10px;
    }
    .rs-price-unit {
      font-family: var(--font-label);
      font-size: 11px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--text-muted);
    }
    .rs-price-copy p {
      font-size: 15px;
      line-height: 1.7;
      color: var(--text-muted);
      margin-bottom: 13px;
    }
    .rs-price-copy p:last-child { margin-bottom: 0; }
    .rs-price-copy .rs-price-note {
      font-family: var(--font-label);
      font-size: 11px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--text);
    }

    /* ── WAITLIST ── */
    .rs-notify { max-width: 600px; text-align: center; padding-bottom: 200px; }
    .rs-notify-line {
      font-size: 16px;
      line-height: 1.7;
      color: var(--text-muted);
      margin: 18px auto 36px;
      max-width: 470px;
    }
    .rs-form { display: flex; gap: 8px; justify-content: center; align-items: stretch; }
    .rs-input {
      flex: 1 1 auto;
      max-width: 300px;
      background: var(--bg-elev);
      border: 1px solid var(--border);
      color: var(--text-bright);
      font-family: var(--font-body);
      font-size: 15px;
      padding: 13px 14px;
      border-radius: 2px;
      transition: border-color 200ms ease;
    }
    .rs-input::placeholder { color: var(--text-ghost); }
    .rs-input:focus { outline: none; border-color: var(--rs); }
    .rs-submit {
      font-family: var(--font-label);
      font-size: 11px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--bg-deep);
      background: var(--rs);
      border: 1px solid var(--rs);
      padding: 0 22px;
      border-radius: 2px;
      cursor: pointer;
      transition: background 0.3s ease, color 0.3s ease;
    }
    .rs-submit:hover { background: transparent; color: var(--rs); }
    .rs-form-error { font-style: italic; font-size: 13px; color: var(--rs); margin-top: 12px; }
    .rs-form-done { font-style: italic; font-size: 14px; color: var(--text-muted); margin-top: 4px; }
    .rs-notify.is-done .rs-form,
    .rs-notify.is-done .rs-notify-line { display: none; }

    /* ── RESPONSIVE ── */
    @media (max-width: 900px) {
      .rs-stages { grid-template-columns: repeat(2, 1fr); }
      .rs-stock-groups { grid-template-columns: repeat(2, 1fr); gap: 28px 32px; }
      .rs-specs { grid-template-columns: 1fr; }
      .rs-price-box { grid-template-columns: 1fr; }
    }
    @media (max-width: 560px) {
      .rs-stages { grid-template-columns: 1fr; }
      .rs-stock-groups { grid-template-columns: 1fr; }
      .rs-path-row { flex-wrap: wrap; gap: 8px; }
      .rs-path-from { min-width: 0; }
      .rs-form { flex-direction: column; align-items: center; }
      .rs-input { max-width: none; width: 100%; }
      .rs-submit { padding: 13px; width: 100%; }
    }

    /* hero reel styles live in the HERO REEL block above */

    /* ── ONE NODE / COLOR MANAGED ── */
    .rs-node { max-width: 1000px; text-align: center; }
    .rs-node-lead { margin-left: auto; margin-right: auto; }
    .rs-flow { margin-top: 48px; display: flex; align-items: stretch; justify-content: center; gap: 14px; flex-wrap: wrap; }
    .rs-flow-step {
      flex: 1 1 240px; max-width: 320px;
      background: var(--bg); border: 1px solid var(--border); border-radius: 4px;
      padding: 22px 20px; display: flex; flex-direction: column; justify-content: center;
    }
    .rs-flow-engine { border-color: var(--rs-dim); }
    .rs-flow-k { font-family: var(--font-label); font-size: 10px; letter-spacing: 0.24em; text-transform: uppercase; color: var(--rs); margin-bottom: 10px; }
    .rs-flow-v { font-family: var(--font-display); font-weight: 300; font-size: 15px; line-height: 1.5; color: var(--text-bright); }
    .rs-flow-arrow { align-self: center; color: var(--rs); font-size: 18px; }
    .rs-node-foot { margin-top: 24px; font-family: var(--font-label); font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--text-muted); }
    @media (max-width: 640px) {
      .rs-flow { flex-direction: column; align-items: center; }
      .rs-flow-arrow { transform: rotate(90deg); }
      .rs-flow-step { max-width: none; width: 100%; }
    }

    /* ── SCENE × STOCK SWITCHER ── */
    .rs-switch-wrap { max-width: 1100px; text-align: center; }
    .rs-switch-lead { margin-left: auto; margin-right: auto; }
    .rs-switch { margin-top: 44px; display: grid; grid-template-columns: 1fr 190px; gap: 26px; align-items: start; }
    .rs-switch-frame { position: relative; aspect-ratio: 16 / 9; border: 1px solid var(--border); border-radius: 6px; overflow: hidden; background: var(--bg-deep); }
    .rs-switch-img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0; transition: opacity 350ms ease; }
    .rs-switch-img.is-active { opacity: 1; }
    .rs-switch-cap { position: absolute; left: 12px; bottom: 12px; z-index: 2; font-family: var(--font-label); font-size: 11px; letter-spacing: 0.08em; color: var(--text-bright); background: rgba(18, 16, 14, 0.62); padding: 6px 11px; border-radius: 3px; }
    .rs-switch-cap [data-cap-look] { color: var(--rs); }
    .rs-switch-stocks { display: flex; flex-direction: column; gap: 8px; }
    .rs-switch-group { display: none; flex-direction: column; gap: 8px; width: 100%; }
    .rs-switch-group.is-active { display: flex; }
    .rs-switch-stock { font-family: var(--font-label); font-size: 11px; letter-spacing: 0.06em; text-align: left; color: var(--text-muted); background: none; border: 1px solid var(--border); border-radius: 3px; padding: 11px 13px; cursor: pointer; transition: color .2s, background .2s, border-color .2s; }
    .rs-switch-stock:hover { color: var(--text); border-color: var(--border-light); }
    .rs-switch-stock.is-active { color: var(--bg-deep); background: var(--rs); border-color: var(--rs); }
    .rs-switch-thumbs { margin-top: 22px; display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
    .rs-switch-thumb { background: none; border: 0; padding: 0; cursor: pointer; width: 104px; }
    .rs-switch-thumb img { width: 100%; aspect-ratio: 16 / 9; object-fit: cover; border-radius: 3px; border: 1px solid var(--border); opacity: 0.5; transition: opacity .2s, border-color .2s; }
    .rs-switch-thumb.is-active img { opacity: 1; border-color: var(--rs); }
    .rs-switch-thumb span { display: block; margin-top: 7px; font-family: var(--font-label); font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-muted); }
    .rs-switch-thumb.is-active span { color: var(--rs); }
    @media (max-width: 760px) {
      .rs-switch { grid-template-columns: 1fr; }
      .rs-switch-group { flex-direction: row; flex-wrap: wrap; justify-content: center; }
    }
  </style>

  <script>
    document.querySelectorAll('.rs-switch-wrap').forEach((wrap) => {
      const sw = wrap.querySelector('[data-switch]');
      if (!sw) return;
      const imgs = sw.querySelectorAll('.rs-switch-img');
      const groups = sw.querySelectorAll('[data-stock-group]');
      const stockBtns = sw.querySelectorAll('.rs-switch-stock');
      const frameBtns = wrap.querySelectorAll('[data-frame-btn]');
      const capLook = wrap.querySelector('[data-cap-look]');
      const lookBtn = (f, l) => sw.querySelector('.rs-switch-stock[data-frame="' + f + '"][data-look="' + l + '"]');
      const lookName = (f, l) => { const b = lookBtn(f, l); return b ? b.textContent : ''; };
      let frame = 0, look = 0;
      const update = () => {
        imgs.forEach((im) => im.classList.toggle('is-active', +im.dataset.frame === frame && +im.dataset.look === look));
        groups.forEach((g) => g.classList.toggle('is-active', +g.dataset.stockGroup === frame));
        stockBtns.forEach((b) => b.classList.toggle('is-active', +b.dataset.frame === frame && +b.dataset.look === look));
        frameBtns.forEach((b) => b.classList.toggle('is-active', +b.dataset.frameBtn === frame));
        if (capLook) capLook.textContent = lookName(frame, look);
      };
      stockBtns.forEach((b) => b.addEventListener('click', () => { frame = +b.dataset.frame; look = +b.dataset.look; update(); }));
      frameBtns.forEach((b) => b.addEventListener('click', () => {
        const nf = +b.dataset.frameBtn;
        const keep = lookName(frame, look);
        let nl = 0;
        sw.querySelectorAll('.rs-switch-stock[data-frame="' + nf + '"]').forEach((c) => { if (c.textContent === keep) nl = +c.dataset.look; });
        frame = nf; look = nl; update();
      }));
      update();
    });
  </script>
</Base>
