---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Base
  title="Refund Policy — Latent"
  description="Refunds for purchases made through latentritual.com and guidance for App Store purchases."
>
  <Nav />
  <main class="legal" id="main">
    <div class="legal-label">Refunds</div>
    <h1>Refund Policy</h1>
    <p class="legal-updated">Last updated 9 June 2026</p>

    <p>This policy applies to purchases made on latentritual.com.</p>

    <h2>Website purchases</h2>
    <p>Website purchases are processed by Paddle. For The Lab / OFX plugin, you may request a refund within 14 days of purchase by emailing <a href="mailto:contact@latentritual.com">contact@latentritual.com</a> with the email address used at checkout and your Paddle receipt or transaction ID.</p>

    <h2>Approved refunds</h2>
    <p>If a refund is approved, access to the plugin, license, or related updates may be revoked. Refunds are returned to the original payment method through Paddle.</p>

    <h2>Subscriptions</h2>
    <p>If website subscriptions are offered in the future, they may be cancelled at any time. Cancelling prevents future billing but does not automatically refund previous payments unless required by law or approved by us.</p>

    <h2>App Store purchases</h2>
    <p>Purchases made through Apple's App Store are handled by Apple and follow Apple's own refund process. We cannot issue refunds directly for App Store purchases.</p>

    <h2>Your rights</h2>
    <p>Nothing in this policy limits any consumer rights you may have under local law.</p>

    <h2>Contact</h2>
    <p>Questions? Email <a href="mailto:contact@latentritual.com">contact@latentritual.com</a>.</p>

    <a class="legal-back" href="/">← Back to Latent</a>
  </main>
  <Footer />

  <style>
    .legal { max-width: 720px; margin: 0 auto; padding: 140px 24px 120px; }
    .legal-label { font-family: var(--font-label); font-weight: 300; font-size: 10px; letter-spacing: 0.28em; text-transform: uppercase; color: var(--amber-dim); margin-bottom: 20px; }
    .legal h1 { font-family: var(--font-display); font-weight: 300; font-size: 40px; letter-spacing: -0.01em; color: var(--text-bright); margin-bottom: 12px; }
    .legal-updated { font-family: var(--font-body); font-style: italic; font-size: 14px; color: var(--text-ghost); margin-bottom: 48px; }
    .legal h2 { font-family: var(--font-display); font-weight: 400; font-size: 21px; color: var(--text-bright); margin: 40px 0 12px; }
    .legal p { font-family: var(--font-body); font-weight: 300; font-size: 16px; line-height: 1.7; color: var(--text-muted); margin-bottom: 14px; }
    .legal a { color: var(--amber); text-decoration: none; border-bottom: 1px solid var(--border-light); }
    .legal a:hover { color: var(--text-bright); }
    .legal-back { display: inline-block; margin-top: 48px; font-family: var(--font-label); font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--amber-dim); border-bottom: none; }
    .legal-back:hover { color: var(--text-bright); }
  </style>
</Base>
