  </style>
  <script>
    // Press and hold a frame to drop back to its negative; release and it
    // develops again — the same gesture as The Develop on the home page.
    document.querySelectorAll('.mdev').forEach((dev) => {
      const after = dev.querySelector('.mdev-after');
      if (!(after instanceof HTMLElement)) return;
      const hold = () => dev.classList.add('is-held');
      const release = () => {
        if (!dev.classList.contains('is-held')) return;
        dev.classList.remove('is-held');
        after.classList.remove('is-developing');
        void after.offsetWidth; // restart the animation
        after.classList.add('is-developing');
        after.addEventListener('animationend', () => after.classList.remove('is-developing'), { once: true });
      };
      dev.addEventListener('pointerdown', hold);
      dev.addEventListener('pointerup', release);
      dev.addEventListener('pointercancel', release);
      dev.addEventListener('pointerleave', release);
      dev.addEventListener('contextmenu', (e) => e.preventDefault());
      dev.addEventListener('keydown', (e) => {
        if (e.key === ' ' || e.key === 'Enter') { e.preventDefault(); hold(); }
      });
      dev.addEventListener('keyup', (e) => {
        if (e.key === ' ' || e.key === 'Enter') release();
      });
    });

    // One image, a theme toggle underneath: clicking a name crossfades to
    // that theme's screenshot.
    document.querySelectorAll('[data-mtoggle]').forEach((group) => {
      const imgs = group.querySelectorAll('.mtoggle-img');
      const btns = group.querySelectorAll('.mtoggle-btn');
      group.addEventListener('click', (e) => {
        const btn = e.target instanceof Element && e.target.closest('.mtoggle-btn');
        if (!(btn instanceof HTMLElement) || !btn.dataset.target) return;
        const theme = btn.dataset.target;
        for (const b of btns) b.classList.toggle('is-active', b === btn);
        for (const img of imgs) img.classList.toggle('is-active', img instanceof HTMLElement && img.dataset.theme === theme);
      });
    });
  </script>
</Base>
