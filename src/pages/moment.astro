---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const stages = [
  { name: 'Film', sub: 'Origin', body: 'Every photograph starts as a film stock. Portra, Velvia, Tri-X, each shapes the light its own way. Choose yours first; everything else builds on it.' },
  { name: 'Light', sub: 'Interpret', body: "Exposure, contrast, the wash of a tone. The photographer's hand, shaping what's already there, not adding what isn't." },
  { name: 'Paper', sub: 'Realize', body: 'Glossy or matte, warm or cool, the paper a photograph lives on changes how it speaks. The print is where the developing ends.' },
];
---

<Base
  title="The Moment — Latent for iPhone"
  description="The Moment is Latent on iPhone, a journal for the photographs you catch in passing. The same developing engine as the Ritual, carried in your pocket."
  ogImage="/og-moment.png?v=1"
  ogImageAlt="The Moment — Latent for iPhone"
>
  <Nav />
  <main class="mpage" id="main">
    <section class="mpage-hero">
      <div class="mpage-mark reveal">Latent</div>
      <div class="mpage-sub reveal" style="--reveal-delay: 80ms">The Moment</div>
      <h1 class="mpage-tagline reveal reveal-heading" style="--reveal-delay: 200ms">A photographer's journal, on iPhone.</h1>
      <p class="mpage-lead reveal" style="--reveal-delay: 300ms">A photographic developer. Not a filter app. A darkroom you carry.</p>
    </section>

    <section class="mpage-device">
      <div class="mphone reveal">
        <div class="mphone-screen">
          <video class="mphone-video" autoplay muted loop playsinline poster="/moment-develop-poster.webp">
            <source src="/moment-develop.webm" type="video/webm" />
            <source src="/moment-develop.mp4" type="video/mp4" />
          </video>
        </div>
      </div>
      <p class="mdevice-cap reveal" style="--reveal-delay: 120ms">Film, light, paper. The whole darkroom, in your hand.</p>
    </section>

    <section class="mpage-camera">
      <div class="mcam-label reveal">A camera in your pocket</div>
      <h2 class="mcam-h reveal reveal-heading" style="--reveal-delay: 80ms">Shoots raw. Nothing else.</h2>
      <p class="mcam-lead reveal" style="--reveal-delay: 140ms">A light, fast point-and-shoot built into the app, no AI, no neural “enhancement,” no smart anything. You pick your film and see it live on the glass as you frame, then shoot a clean RAW negative that lands straight in your library, ready to develop. Already have the shot? Import any RAW from your photos and develop it at full quality, on the go.</p>
      <div class="mcam-phone reveal" style="--reveal-delay: 200ms">
        <div class="mphone">
          <div class="mphone-screen">
            <video autoplay muted loop playsinline preload="metadata" poster="/moment-livecam-poster.jpg" aria-label="The Latent the Moment camera, the chosen film stock previewing live in the viewfinder while scrolling through stocks">
              <source src="/moment-livecam.webm" type="video/webm" />
              <source src="/moment-livecam.mp4" type="video/mp4" />
            </video>
          </div>
        </div>
      </div>
      <p class="mshot-cap reveal" style="--reveal-delay: 260ms">The film is on the glass while you frame, not added after. Scroll the stocks and watch the light change.</p>
    </section>

    <section class="mpage-takes">
      <div class="mcam-label reveal">Takes</div>
      <h2 class="mcam-h reveal reveal-heading" style="--reveal-delay: 80ms">Hold the shutter, and the film runs.</h2>
      <p class="mcam-lead reveal" style="--reveal-delay: 140ms">The Moment films, too. A take is a moving print, your film carried onto real footage, its negative kept alongside. Develop it in its own small lab, keep it in the album, or hand it to the Circle.</p>
    </section>

    <section class="mpage-prose">
      <p class="reveal">A place to keep your photographs, not to perfect them. To keep them. The Ritual is for the photographs you sit with; the Moment is for the ones you catch in passing. The same engine, on a slower bench.</p>
    </section>

    <section class="mpage-ba-wrap">
      <div class="mba-label reveal">The develop</div>
      <h2 class="mba-h reveal reveal-heading" style="--reveal-delay: 80ms">From a flat negative to a finished frame.</h2>
      <button class="mdev reveal" type="button" style="--reveal-delay: 160ms" aria-label="Press and hold to see the negative">
        <img class="mdev-before" src="/moment-raw.webp" alt="The same frame, straight from the iPhone camera" loading="lazy" draggable="false" />
        <img class="mdev-after" src="/moment-photo.webp" alt="The chapel, developed in Latent the Moment" loading="lazy" draggable="false" />
        <span class="mdev-tag">Press and hold</span>
      </button>
      <p class="mshot-cap reveal" style="--reveal-delay: 220ms">Joun, golden hour. Straight from camera, then developed on Kodak. Press and hold to see the negative.</p>
    </section>

    <section class="mpage-stages">
      {stages.map((s, i) => (
        <div class="mstage reveal" style={`--reveal-delay: ${i * 80}ms`}>
          <div class="mstage-name">{s.name}</div>
          <div class="mstage-sub">{s.sub}</div>
          <p class="mstage-body">{s.body}</p>
        </div>
      ))}
    </section>

    <section class="mpage-themes">
      <div class="mthemes-label reveal">Two rooms, one darkroom</div>
      <h2 class="mthemes-h reveal reveal-heading" style="--reveal-delay: 80ms">Work in daylight, or by candlelight.</h2>
      <p class="mthemes-lead reveal" style="--reveal-delay: 160ms">The Journal, bright and papery. The Evening, dark and quiet. Same controls; your mood.</p>
      <div class="mtoggle reveal" style="--reveal-delay: 220ms" data-mtoggle>
        <div class="mtoggle-frame mtoggle-phone">
          <img class="mtoggle-img is-active" data-theme="journal" src="/moment-app.webp" alt="Latent the Moment in its light Journal theme" loading="lazy" />
          <img class="mtoggle-img" data-theme="evening" src="/moment-evening.webp" alt="Latent the Moment in its dark Evening theme" loading="lazy" />
        </div>
        <div class="mtoggle-btns" role="group" aria-label="Choose a theme">
          <button class="mtoggle-btn is-active" type="button" data-target="journal">The Journal</button>
          <button class="mtoggle-btn" type="button" data-target="evening">The Evening</button>
        </div>
      </div>
    </section>

    <section class="mpage-review">
      <div class="mcam-label reveal">Review and release</div>
      <h2 class="mcam-h reveal reveal-heading" style="--reveal-delay: 80ms">Keep what's worth keeping.</h2>
      <p class="mcam-lead reveal" style="--reveal-delay: 140ms">Step through the frames one by one, star the keepers, let the rest go. Release the rejects, RAWs and all, so your library holds only what you meant to keep.</p>
      <div class="mcam-phone reveal" style="--reveal-delay: 200ms">
        <div class="mphone">
          <div class="mphone-screen">
            <video class="mphone-video" autoplay muted loop playsinline poster="/moment-review-poster.webp">
              <source src="/moment-review.webm" type="video/webm" />
              <source src="/moment-review.mp4" type="video/mp4" />
            </video>
          </div>
        </div>
      </div>
    </section>

    <section class="mpage-note">
      <div class="mnote-label reveal">Keep the story</div>
      <blockquote class="mnote-quote reveal" style="--reveal-delay: 80ms">“A sunset walk with a friend, in the softness of an early summer evening.”</blockquote>
      <p class="mnote-cap reveal" style="--reveal-delay: 160ms">Every frame can carry a caption, a place, a date. So a photograph stays a memory, not just a file.</p>
    </section>

    <section class="mpage-sheet">
      <div class="msheet-label reveal">A page from the journal</div>
      <h2 class="msheet-h reveal reveal-heading" style="--reveal-delay: 80ms">Your afternoon, in eight frames.</h2>
      <p class="msheet-lead reveal" style="--reveal-delay: 160ms">Every session becomes a page: one moment across the stocks you tried, dated and titled. Keep it, or share it exactly as it is.</p>
      <div class="mtoggle reveal" style="--reveal-delay: 220ms" data-mtoggle>
        <div class="mtoggle-frame mtoggle-sheet">
          <img class="mtoggle-img is-active" data-theme="journal" src="/moment-contact.webp" alt="A Latent contact sheet titled This afternoon, eight frames across Portra 800, Portra 400, Ultra 100, Tri-X 400 and Vision3 250D" loading="lazy" />
          <img class="mtoggle-img" data-theme="evening" src="/moment-contact-evening.webp" alt="The same contact sheet rendered in the dark Evening theme" loading="lazy" />
        </div>
        <div class="mtoggle-btns" role="group" aria-label="Choose a theme">
          <button class="mtoggle-btn is-active" type="button" data-target="journal">The Journal</button>
          <button class="mtoggle-btn" type="button" data-target="evening">The Evening</button>
        </div>
      </div>
    </section>

    <section class="mpage-ba-wrap">
      <div class="mba-label reveal">Another negative</div>
      <h2 class="mba-h reveal reveal-heading" style="--reveal-delay: 80ms">Every frame begins flat.</h2>
      <button class="mdev mdev-portrait reveal" type="button" style="--reveal-delay: 160ms" aria-label="Press and hold to see the negative">
        <img class="mdev-before" src="/moment-raw2.webp" alt="The same frame, straight from the iPhone camera" loading="lazy" draggable="false" />
        <img class="mdev-after" src="/moment-photo2.webp" alt="Queen Anne's lace at dusk, developed in Latent the Moment" loading="lazy" draggable="false" />
        <span class="mdev-tag">Press and hold</span>
      </button>
      <p class="mshot-cap reveal" style="--reveal-delay: 220ms">Dusk in the fields, the same negative, developed. Press and hold to see the negative.</p>
    </section>

    <section class="mpage-take">
      <div class="mtake-label reveal">Take it anywhere</div>
      <h2 class="mtake-h reveal reveal-heading" style="--reveal-delay: 80ms">Export full quality. Share it framed.</h2>
      <p class="mtake-lead reveal" style="--reveal-delay: 140ms">Save a JPEG for the group chat or a 16-bit TIFF for the archive. Full resolution, your call. Or share it as a framed print, signed with the film it was made on.</p>
      <div class="mtake-pair reveal" style="--reveal-delay: 200ms">
        <figure class="mtake-fig">
          <img src="/moment-export.webp" alt="The Latent export sheet, JPEG, TIFF 8, TIFF 16 or Original, at high quality" loading="lazy" />
          <figcaption>Export</figcaption>
        </figure>
        <figure class="mtake-fig">
          <img src="/moment-framed.webp" alt="A framed Latent export, a street photograph on Kodak Vision3 250D, June 2026" loading="lazy" />
          <figcaption>Framed</figcaption>
        </figure>
      </div>
    </section>

    <section class="mpage-circle">
      <div class="mcircle-label reveal">The Circle</div>
      <h2 class="mcircle-h reveal reveal-heading" style="--reveal-delay: 80ms">Show your work to the people who'd get it.</h2>
      <p class="mcircle-lead reveal" style="--reveal-delay: 140ms">Not a feed for the whole world. A small circle, a single person, or just you. Send a frame or a whole page, let someone keep it, talk it over in the margins. The quiet opposite of posting.</p>
      <div class="mcircle-tiers reveal" style="--reveal-delay: 200ms">
        <div class="mcircle-tier">
          <div class="mcircle-tier-name">A circle</div>
          <p>The few people you'd actually show a print to.</p>
        </div>
        <div class="mcircle-tier">
          <div class="mcircle-tier-name">One person</div>
          <p>An envelope addressed to a single name.</p>
        </div>
        <div class="mcircle-tier">
          <div class="mcircle-tier-name">Only you</div>
          <p>A private copy that stays on your shelf.</p>
        </div>
      </div>
      <p class="mcircle-coda reveal" style="--reveal-delay: 260ms">Keeps instead of likes, words instead of a scroll. And what you choose to keep is yours to show, or to hold. It all lives in your own iCloud, and you hear the knock the moment someone steps in.</p>
    </section>

    <section class="mpage-closing">
      <p class="reveal">The same developing engine as <a href="/#ritual">The Ritual</a>: the spectral film stocks, the papers, the light, carried in your pocket.</p>
      <p class="mclosing-coda reveal" style="--reveal-delay: 120ms">Develop slowly. Look often. Keep what catches you.</p>
    </section>
  </main>
  <Footer />

  <style>
    /* The Moment's own page — its own light world: the app's "The Journal"
       theme (cream #F4EFE8 ground, ink text, terracotta #C06A3E accent) set in
       Lora serif. The dark Nav/Footer bracket it like covers around a page.
       Media (photographs + film) drops into mpage-prose / a gallery later. */
    .mpage { background: #F4EFE8; min-height: 100vh; }

    .mpage-hero {
      text-align: center;
      padding: 168px 24px 96px;
      max-width: 760px;
      margin: 0 auto;
    }
    .mpage-mark {
      font-family: 'Lora', Georgia, serif;
      font-weight: 500;
      font-size: clamp(52px, 11vw, 84px);
      line-height: 1;
      letter-spacing: -0.01em;
      color: #1E1814;
      margin-bottom: 12px;
    }
    .mpage-sub {
      font-family: 'Lora', Georgia, serif;
      font-weight: 400;
      font-size: 18px;
      letter-spacing: 0.24em;
      color: #C06A3E;
      margin-bottom: 52px;
    }
    .mpage-tagline {
      font-family: 'Lora', Georgia, serif;
      font-weight: 400;
      font-size: clamp(28px, 5vw, 38px);
      line-height: 1.25;
      color: #1E1814;
      margin-bottom: 26px;
    }
    .mpage-lead {
      font-family: 'Lora', Georgia, serif;
      font-weight: 400;
      font-style: italic;
      font-size: 20px;
      line-height: 1.6;
      color: #7A6E62;
    }
    .mpage-prose {
      max-width: 640px;
      margin: 0 auto;
      padding: 24px 24px 120px;
      text-align: center;
    }
    .mpage-prose p {
      font-family: 'Lora', Georgia, serif;
      font-weight: 400;
      font-size: 22px;
      line-height: 1.7;
      color: #483C32;
    }
    .mpage-stages {
      max-width: 980px;
      margin: 0 auto;
      padding: 0 24px 120px;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 52px;
    }
    .mstage-name {
      font-family: 'Lora', Georgia, serif;
      font-weight: 500;
      font-size: 30px;
      color: #1E1814;
      margin-bottom: 4px;
    }
    .mstage-sub {
      font-family: var(--font-label);
      font-weight: 400;
      font-size: 10px;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: #C06A3E;
      margin-bottom: 18px;
    }
    .mstage-body {
      font-family: 'Lora', Georgia, serif;
      font-weight: 400;
      font-size: 16px;
      line-height: 1.65;
      color: #7A6E62;
    }
    .mpage-closing {
      max-width: 640px;
      margin: 0 auto;
      padding: 0 24px 160px;
      text-align: center;
    }
    .mpage-closing p {
      font-family: 'Lora', Georgia, serif;
      font-style: italic;
      font-size: 22px;
      line-height: 1.6;
      color: #483C32;
    }
    .mpage-closing a {
      color: #C06A3E;
      text-decoration: none;
      border-bottom: 1px solid #D4CBC0;
    }
    .mpage-closing a:hover { color: #1E1814; }

    /* ── MEDIA from the app captures: phone, a photograph, the contact sheet ── */
    .mpage-device { max-width: 760px; margin: 0 auto; padding: 8px 24px 110px; text-align: center; }
    .mphone {
      width: 268px; max-width: 76vw; margin: 0 auto;
      background: #14110F; border-radius: 46px; padding: 10px;
      box-shadow: 0 34px 70px -34px rgba(30, 24, 20, 0.55);
    }
    .mphone-screen { border-radius: 37px; overflow: hidden; line-height: 0; }
    .mphone-screen img { width: 100%; height: auto; }
    .mdevice-cap {
      font-family: 'Lora', Georgia, serif; font-style: italic;
      font-size: 16px; line-height: 1.6; color: #7A6E62;
      max-width: 420px; margin: 30px auto 0;
    }
    .mpage-shot { max-width: 1080px; margin: 0 auto; padding: 0 24px 120px; text-align: center; }
    .mshot-img { width: 100%; height: auto; border-radius: 3px; display: block; }
    .mshot-cap {
      font-family: 'Lora', Georgia, serif; font-style: italic;
      font-size: 15px; line-height: 1.6; color: #7A6E62; margin-top: 18px;
    }
    .mpage-sheet { max-width: 860px; margin: 0 auto; padding: 0 24px 120px; text-align: center; }
    .msheet-label {
      font-family: var(--font-label); font-weight: 400; font-size: 10px;
      letter-spacing: 0.24em; text-transform: uppercase; color: #C06A3E; margin-bottom: 18px;
    }
    .msheet-h {
      font-family: 'Lora', Georgia, serif; font-weight: 500;
      font-size: clamp(24px, 4vw, 32px); line-height: 1.2; color: #1E1814;
    }
    .msheet-lead {
      font-family: 'Lora', Georgia, serif; font-size: 18px; line-height: 1.7;
      color: #7A6E62; max-width: 540px; margin: 16px auto 40px;
    }
    .msheet-img {
      width: 100%; max-width: 560px; height: auto; display: block; margin: 0 auto;
      border: 1px solid #D4CBC0; border-radius: 4px;
      box-shadow: 0 24px 60px -32px rgba(30, 24, 20, 0.4);
    }

    .mphone-screen video { width: 100%; height: auto; display: block; }
    .mpage-themes { max-width: 820px; margin: 0 auto; padding: 0 24px 120px; text-align: center; }
    .mthemes-label { font-family: var(--font-label); font-weight: 400; font-size: 10px; letter-spacing: 0.24em; text-transform: uppercase; color: #C06A3E; margin-bottom: 18px; }
    .mthemes-h { font-family: 'Lora', Georgia, serif; font-weight: 500; font-size: clamp(24px, 4vw, 32px); line-height: 1.2; color: #1E1814; }
    .mthemes-lead { font-family: 'Lora', Georgia, serif; font-size: 18px; line-height: 1.7; color: #7A6E62; max-width: 520px; margin: 16px auto 44px; }
    /* ── One image, a theme toggle underneath ── */
    .mtoggle { margin: 0 auto; }
    .mtoggle-frame { position: relative; margin: 0 auto; }
    .mtoggle-img { width: 100%; height: auto; display: block; transition: opacity 0.35s ease; }
    .mtoggle-img:not(.is-active) { position: absolute; top: 0; left: 0; opacity: 0; pointer-events: none; }
    .mtoggle-phone { max-width: 248px; }
    .mtoggle-phone .mtoggle-img { border-radius: 26px; border: 1px solid #D4CBC0; box-shadow: 0 24px 50px -28px rgba(30, 24, 20, 0.4); }
    .mtoggle-sheet { max-width: 520px; }
    .mtoggle-sheet .mtoggle-img { border: 1px solid #D4CBC0; border-radius: 4px; box-shadow: 0 24px 50px -30px rgba(30, 24, 20, 0.4); }
    .mtoggle-btns { display: inline-flex; gap: 6px; margin-top: 22px; padding: 4px; border: 1px solid #D4CBC0; border-radius: 999px; }
    .mtoggle-btn { font-family: var(--font-label); font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: #7A6E62; background: none; border: 0; padding: 8px 16px; border-radius: 999px; cursor: pointer; transition: color 0.25s ease, background 0.25s ease; }
    .mtoggle-btn.is-active { color: #1E1814; background: #E7DECF; }

    /* ── Press and hold to see the negative, matching The Develop on home ── */
    .mpage-ba-wrap { max-width: 1000px; margin: 0 auto; padding: 0 24px 120px; text-align: center; }
    .mba-label, .mnote-label, .mframed-label { font-family: var(--font-label); font-weight: 400; font-size: 10px; letter-spacing: 0.24em; text-transform: uppercase; color: #C06A3E; margin-bottom: 18px; }
    .mba-h, .mframed-h { font-family: 'Lora', Georgia, serif; font-weight: 500; font-size: clamp(24px, 4vw, 32px); line-height: 1.2; color: #1E1814; }
    .mdev { position: relative; display: block; width: 100%; max-width: 880px; margin: 40px auto 0; padding: 0; border: 0; background: none; cursor: pointer; border-radius: 4px; overflow: hidden; border: 1px solid #D4CBC0; -webkit-touch-callout: none; user-select: none; touch-action: manipulation; }
    .mdev-portrait { max-width: 520px; }
    .mdev img { width: 100%; height: auto; display: block; }
    .mdev-after { position: absolute; inset: 0; transition: opacity 0.32s ease; }
    .mdev.is-held .mdev-after { opacity: 0; }
    .mdev-after.is-developing { animation: develop 1100ms cubic-bezier(0.22, 1, 0.36, 1) both; }
    .mdev-tag { position: absolute; bottom: 12px; right: 12px; z-index: 2; font-family: var(--font-label); font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: #F4EFE8; background: rgba(30, 24, 20, 0.5); padding: 5px 10px; border-radius: 3px; pointer-events: none; transition: opacity 0.32s ease; }
    .mdev.is-held .mdev-tag { opacity: 0; }
    .mpage-note { max-width: 680px; margin: 0 auto; padding: 0 24px 120px; text-align: center; }
    .mnote-quote { font-family: 'Lora', Georgia, serif; font-style: italic; font-weight: 400; font-size: clamp(22px, 3.4vw, 30px); line-height: 1.5; color: #1E1814; margin: 0; }
    .mnote-cap { font-family: 'Lora', Georgia, serif; font-size: 16px; line-height: 1.7; color: #7A6E62; max-width: 460px; margin: 24px auto 0; }
    .mpage-framed { max-width: 820px; margin: 0 auto; padding: 0 24px 130px; text-align: center; }
    .mframed-img { width: 100%; max-width: 640px; height: auto; display: block; margin: 40px auto 0; border-radius: 4px; box-shadow: 0 30px 60px -34px rgba(30, 24, 20, 0.4); }

    /* ── Camera, second slider, take-it-anywhere, coda ── */
    .mpage-camera { max-width: 760px; margin: 0 auto; padding: 0 24px 120px; text-align: center; }
    .mcam-label, .mtake-label { font-family: var(--font-label); font-weight: 400; font-size: 10px; letter-spacing: 0.24em; text-transform: uppercase; color: #C06A3E; margin-bottom: 18px; }
    .mcam-h, .mtake-h { font-family: 'Lora', Georgia, serif; font-weight: 500; font-size: clamp(24px, 4vw, 32px); line-height: 1.2; color: #1E1814; }
    .mcam-lead, .mtake-lead { font-family: 'Lora', Georgia, serif; font-size: 17px; line-height: 1.7; color: #7A6E62; max-width: 560px; margin: 16px auto 0; }
    .mcam-phone { margin-top: 40px; }
    .mpage-takes { max-width: 760px; margin: 0 auto; padding: 0 24px 120px; text-align: center; }
    .mpage-take { max-width: 860px; margin: 0 auto; padding: 0 24px 120px; text-align: center; }
    .mtake-pair { margin-top: 40px; display: flex; gap: 28px; justify-content: center; align-items: flex-end; flex-wrap: wrap; }
    .mtake-fig { margin: 0; }
    .mtake-fig img { height: 440px; width: auto; max-width: 100%; display: block; border-radius: 14px; border: 1px solid #D4CBC0; box-shadow: 0 24px 50px -30px rgba(30, 24, 20, 0.4); }
    .mtake-fig figcaption { font-family: var(--font-label); font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: #7A6E62; margin-top: 12px; }
    .mclosing-coda { font-family: 'Lora', Georgia, serif; font-style: italic; font-size: 15px; color: #A89C90; margin-top: 22px; }
    @media (max-width: 600px) {
      .mtake-fig img { height: auto; width: 100%; }
      .mtake-pair { align-items: center; gap: 18px; }
    }

    .mpage-circle { max-width: 860px; margin: 0 auto; padding: 0 24px 120px; text-align: center; }
    .mcircle-label { font-family: var(--font-label); font-weight: 400; font-size: 10px; letter-spacing: 0.24em; text-transform: uppercase; color: #C06A3E; margin-bottom: 18px; }
    .mcircle-h { font-family: 'Lora', Georgia, serif; font-weight: 500; font-size: clamp(24px, 4vw, 32px); line-height: 1.2; color: #1E1814; }
    .mcircle-lead { font-family: 'Lora', Georgia, serif; font-size: 18px; line-height: 1.7; color: #7A6E62; max-width: 580px; margin: 16px auto 0; }
    .mcircle-tiers { margin: 44px auto 0; display: flex; gap: 24px; justify-content: center; flex-wrap: wrap; }
    .mcircle-tier { flex: 0 1 220px; border: 1px solid #D4CBC0; border-radius: 6px; padding: 26px 22px; background: rgba(255, 255, 255, 0.35); }
    .mcircle-tier-name { font-family: 'Lora', Georgia, serif; font-weight: 500; font-size: 19px; color: #1E1814; margin-bottom: 8px; }
    .mcircle-tier p { font-family: 'Lora', Georgia, serif; font-size: 15px; line-height: 1.6; color: #7A6E62; }
