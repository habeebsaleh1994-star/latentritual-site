---
// The Moment — a camera and photographer's journal, on iPhone.
//
// This page speaks Lora serif: headings at 500, body at 400. JetBrains Mono
// keeps to eyebrows, labels, and chips. Release truth (status chip, community
// gate) comes only from src/config/truth.ts.
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import StatusChip from '../components/StatusChip.astro';
import FooterMini from '../components/FooterMini.astro';
import { truth } from '../config/truth';
---

<Base
  title="The Moment — a camera and photographer's journal"
  description="For the ones you catch in passing. Begin at First Light, catch a still photograph or a moving print, and keep the place, the words, and the people around it. The Moment, on iPhone."
  ogImage="/og-moment.png?v=2"
  ogImageAlt="The Moment — a camera and photographer's journal, on iPhone"
>
  <Fragment slot="head">
    {/* The viewfinder is this page's LCP image. */}
    <link
      rel="preload"
      as="image"
      href="/moment-firstlight-900.webp"
      imagesrcset="/moment-firstlight-600.webp 600w, /moment-firstlight-900.webp 900w"
      imagesizes="(max-width: 428px) 70vw, 300px"
      fetchpriority="high"
    />
  </Fragment>

  <Nav cta={{ label: 'Join the beta', href: '#join' }} />
  <main id="main">
    <!-- HERO -->
    <section class="moment-hero">
      <div class="safelight-pulse" aria-hidden="true"></div>
      <div class="hero-grid">
        <div>
          <div class="eyebrow hero-eyebrow">The Moment &middot; iPhone</div>
          <h1 class="hero-title">A photographer&rsquo;s journal.</h1>
          <p class="hero-lead">
            For the ones you catch in passing. Begin at First Light, catch a
            still photograph or a moving print, and keep the place, the words,
            and the people around it.
          </p>
        </div>
        <div class="hero-media">
          <div class="phone-frame">
            <img
              src="/moment-firstlight-900.webp"
              srcset="/moment-firstlight-600.webp 600w, /moment-firstlight-900.webp 900w"
              sizes="(max-width: 428px) 70vw, 300px"
              width="900"
              height="1956"
              fetchpriority="high"
              alt="The Moment's viewfinder on iPhone, set to First Light — a sunlit house corner in Joun, ProRAW at 24 megapixels"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- FIRST LIGHT -->
    <section class="passage first-light">
      <div class="eyebrow reveal">First Light</div>
      <h2 class="passage-h reveal reveal-heading" style="--reveal-delay: 80ms">Every photograph begins at First Light.</h2>
      <p class="passage-body reveal" style="--reveal-delay: 200ms">
        Not a raw exposure waiting to be fixed &mdash; a first, human
        interpretation of what you saw. Keep it, or carry the photograph on to
        an emulsion and a paper. The photograph is never asked to start from
        nothing.
      </p>
    </section>

    <!-- THE CAMERA -->
    <section class="passage camera">
      <div class="eyebrow reveal">The camera</div>
      <h2 class="passage-h reveal reveal-heading" style="--reveal-delay: 80ms">Stills, and Takes.</h2>
      <p class="passage-body reveal" style="--reveal-delay: 200ms">
        Catch a still photograph, or a Take &mdash; a short moving print,
        developed like everything else, never treated as an ordinary video
        clip.
      </p>
      <p class="pull-line reveal" style="--reveal-delay: 280ms">
        The viewfinder is the scene through the film&rsquo;s eye. The print is
        the developed truth.
      </p>
    </section>

    <!-- POCKET DARKROOM -->
    <section class="split darkroom">
      <div class="split-grid">
        <div>
          <div class="eyebrow reveal">The pocket darkroom</div>
          <h2 class="split-h reveal reveal-heading" style="--reveal-delay: 80ms">Film, Light, and Paper<br />&mdash; under your thumb.</h2>
          <p class="split-body reveal" style="--reveal-delay: 200ms">
            The same develop engine as The Ritual, on three quiet shelves.
            Choose an emulsion, interpret the light, realize it on a paper
            &mdash; grain, halation, and all. Nothing here is a filter.
          </p>
          <p class="mono-whisper reveal" style="--reveal-delay: 280ms">One engine, every instrument</p>
        </div>
        <div class="split-media">
          <div class="phone-frame reveal reveal-media" style="--reveal-delay: 200ms">
            <img
              src="/moment-darkroom-900.webp"
              srcset="/moment-darkroom-600.webp 600w, /moment-darkroom-900.webp 900w"
              sizes="(max-width: 428px) 70vw, 300px"
              width="900"
              height="1956"
              loading="lazy"
              alt="The pocket darkroom in The Moment on iPhone — the Film shelf open beneath a photograph of hibiscus against a painted wall, with ColorPlus 200 chosen at 5039 K and no push or pull"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- THE JOURNAL -->
    <section class="split journal">
      <div class="split-grid">
        <div class="split-media">
          <div class="phone-frame reveal reveal-media" style="--reveal-delay: 200ms">
            <img
              src="/moment-journal-900.webp"
              srcset="/moment-journal-600.webp 600w, /moment-journal-900.webp 900w"
              sizes="(max-width: 428px) 70vw, 300px"
              width="900"
              height="1956"
              loading="lazy"
              alt="A day in the journal of The Moment on iPhone — Friday, 17 July, “a summer evening”: twenty frames at First Light above a grid of the day’s photographs"
            />
          </div>
        </div>
        <div>
          <div class="eyebrow reveal">The journal</div>
          <h2 class="split-h reveal reveal-heading" style="--reveal-delay: 80ms">Moments, rolls, and pages.</h2>
          <p class="split-body reveal" style="--reveal-delay: 200ms">
            Photographs keep their place, their time, their captions, and the
            people around them. Review what the day caught, keep what matters,
            and let a roll become a memory you can reread.
          </p>
          <p class="lamplit-line reveal" style="--reveal-delay: 280ms">
            By day the journal is a sunlit page. In the evening, a lamplit room
            &mdash; and the photographs are the brightest things in it.
          </p>
          <p class="ipad-line reveal" style="--reveal-delay: 360ms">On iPad, the same journal opens onto a wider bench.</p>
        </div>
      </div>
    </section>

    <!-- COMPANY -->
    {truth.showCommunity && (
      <section class="passage company">
        <div class="eyebrow reveal">Company</div>
        <h2 class="passage-h reveal reveal-heading" style="--reveal-delay: 80ms">Some photographs are handed on.</h2>
        <p class="passage-body reveal" style="--reveal-delay: 200ms">
          A finished print can go to a <strong>Circle</strong> &mdash; a
          private room of invited people &mdash; or into the open{' '}
          <strong>Field</strong>, where anyone may stop to look.
        </p>
        <p class="mono-whisper reveal" style="--reveal-delay: 280ms">The doors open with the beta</p>
      </section>
    )}

    <!-- CLOSE -->
    <section class="close" id="join">
      <h2 class="close-h reveal reveal-heading">The camera that keeps the story.</h2>
      <div class="close-actions reveal" style="--reveal-delay: 120ms">
        <StatusChip label={truth.momentStatus} />
        <a class="btn-amber" href="/beta?app=moment">Join the beta</a>
      </div>
    </section>
  </main>
  <FooterMini links={[
    { label: 'The Ritual', href: '/ritual' },
    { label: 'The Lab', href: '/lab' },
  ]} />

  <style>
    /* Shared eyebrow — mono caps in dim amber. Every eyebrow here sits 32px
       above its heading. */
    .eyebrow {
      font-family: var(--font-label);
      font-weight: 300;
      font-size: 10px;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--amber-dim);
      margin-bottom: 32px;
    }

    /* The quiet mono end-lines — one under the darkroom, one under Company. */
    .mono-whisper {
      font-family: var(--font-label);
      font-weight: 300;
      font-size: 10px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--text-ghost);
      margin: 0;
    }

    /* HERO */
    .moment-hero {
      padding: 200px 24px 120px;
      max-width: 1400px;
      margin: 0 auto;
      position: relative;
    }
    .moment-hero .safelight-pulse { top: 45%; }
    .hero-grid {
      display: grid;
      grid-template-columns: 1.2fr 1fr;
      gap: 80px;
      align-items: center;
      max-width: 1100px;
      margin: 0 auto;
    }
    .hero-eyebrow {
      opacity: 0;
      animation: lt-rise 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.1s forwards;
    }
    .hero-title {
      font-family: 'Lora', Georgia, serif;
      font-weight: 500;
      font-size: clamp(38px, 4.8vw, 56px);
      line-height: 1.12;
      letter-spacing: -0.01em;
      color: var(--text-bright);
      margin: 0 0 32px;
      opacity: 0;
      animation: lt-rise 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.3s forwards;
    }
    .hero-lead {
      font-family: 'Lora', Georgia, serif;
      font-weight: 400;
      font-size: 19px;
      line-height: 1.7;
      color: var(--text-muted);
      max-width: 480px;
      margin: 0;
      opacity: 0;
      animation: lt-rise 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.5s forwards;
    }
    .hero-media {
      display: flex;
      justify-content: center;
      opacity: 0;
      animation: lt-rise 1.4s cubic-bezier(0.16, 1, 0.3, 1) 0.7s forwards;
    }

    @keyframes lt-rise {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* The phone — the same frame everywhere on this page. */
    .phone-frame {
      width: min(300px, 70vw);
      aspect-ratio: 9 / 19.5;
      border-radius: 24px;
      overflow: hidden;
      box-shadow: 0 40px 80px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(232, 196, 160, 0.07);
      background: var(--bg-deep);
    }
    .phone-frame img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    /* CENTERED PASSAGES — First Light, the camera, Company. */
    .passage {
      padding: 140px 24px;
      max-width: 980px;
      margin: 0 auto;
      text-align: center;
      border-top: 1px solid var(--border);
    }
    .passage-h {
      font-family: 'Lora', Georgia, serif;
      font-weight: 500;
      font-size: 44px;
      line-height: 1.2;
      letter-spacing: -0.005em;
      color: var(--text);
      margin: 0 0 40px;
    }
    .passage-body {
      font-family: 'Lora', Georgia, serif;
      font-weight: 400;
      font-size: 19px;
      line-height: 1.75;
      color: var(--text-muted);
      max-width: 640px;
      margin: 0 auto;
    }
    .camera .passage-body { margin: 0 auto 48px; }
    .pull-line {
      font-family: 'Lora', Georgia, serif;
      font-weight: 400;
      font-style: italic;
      font-size: 22px;
      line-height: 1.5;
      color: var(--text-bright);
      max-width: 560px;
      margin: 0 auto;
    }
    .company .passage-body { margin: 0 auto 40px; }
    .company .passage-body strong {
      color: var(--text);
      font-weight: 500;
    }

    /* SPLITS — the pocket darkroom and the journal. */
    .split {
      padding: 140px 24px;
      max-width: 1400px;
      margin: 0 auto;
      border-top: 1px solid var(--border);
    }
    .split-grid {
      display: grid;
      gap: 80px;
      align-items: center;
      max-width: 1100px;
      margin: 0 auto;
    }
    .darkroom .split-grid { grid-template-columns: 1.2fr 1fr; }
    .journal .split-grid { grid-template-columns: 1fr 1.2fr; }
    .split-media {
      display: flex;
      justify-content: center;
    }
    .split-h {
      font-family: 'Lora', Georgia, serif;
      font-weight: 500;
      font-size: 44px;
      line-height: 1.2;
      letter-spacing: -0.005em;
      color: var(--text);
      margin: 0 0 32px;
    }
    .split-body {
      font-family: 'Lora', Georgia, serif;
      font-weight: 400;
      font-size: 19px;
      line-height: 1.75;
      color: var(--text-muted);
      max-width: 480px;
      margin: 0 0 28px;
    }
    .lamplit-line {
      font-family: 'Lora', Georgia, serif;
      font-weight: 400;
      font-style: italic;
      font-size: 18px;
      line-height: 1.7;
      color: var(--text);
      margin: 0 0 28px;
    }
    .ipad-line {
      font-family: 'Lora', Georgia, serif;
      font-weight: 400;
      font-size: 17px;
      line-height: 1.7;
      color: var(--text-ghost);
      margin: 0;
    }

    /* CLOSE */
    .close {
      padding: 160px 24px 180px;
      max-width: 720px;
      margin: 0 auto;
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 36px;
      border-top: 1px solid var(--border);
    }
    .close-h {
      font-family: 'Lora', Georgia, serif;
      font-weight: 500;
      font-size: 36px;
      line-height: 1.25;
      letter-spacing: -0.005em;
      color: var(--text-bright);
      margin: 0;
    }
    .close-actions {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 24px;
      flex-wrap: wrap;
    }

    /* Responsive — the old repo's breakpoint discipline. */
    @media (max-width: 900px) {
      .hero-grid,
      .darkroom .split-grid,
      .journal .split-grid {
        grid-template-columns: 1fr;
        gap: 40px;
      }
      /* Single column: capture first, text second. */
      .hero-media,
      .darkroom .split-media { order: -1; }
      .passage-h,
      .split-h { font-size: 36px; }
    }

    @media (max-width: 640px) {
      .moment-hero { padding: 140px 20px 80px; }
      .passage,
      .split { padding: 100px 20px; }
      .close { padding: 100px 20px 120px; }
    }

    @media (prefers-reduced-motion: reduce) {
      .hero-eyebrow,
      .hero-title,
      .hero-lead,
      .hero-media {
        animation: none;
        opacity: 1;
      }
    }
  </style>
</Base>
